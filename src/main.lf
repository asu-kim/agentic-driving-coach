/*
* sudo usermod -aG input raspdeeksha
* sudo usermod -aG video raspdeeksha
* to test the device $ python -m evdev.evtest
* * https://python-evdev.readthedocs.io/en/latest/apidoc.html#evdev.events.InputEvent to understand the evdev python library for linux
*/


target Python {keepalive: true}

import DeviceReader from "sensor_reader.lf"
import FaceLandmark from "head_pose_estimation.lf"
preamble{=
  import cv2
=}


reactor steering_wheel{
   input steer
   state deadzone = 0.04
   reaction(steer){=
        s = steer.value
        dz = self.deadzone

        if s < -dz:
            print("LEFT")
        elif s > dz:
            print("RIGHT")
        else:
            print("STRAIGHT")
   =}
}

reactor accelerator{
    input accelerate
    reaction(accelerate) {=
    a = accelerate.value
    print(f"Accelerate {a:.4f}")
  =}
}

reactor brake{
    input brake
     reaction(brake) {=
    b = brake.value
    print(f"Brake {b:.4f}")
  =}
}

reactor webcam{
    input vid 
    output frame_fps
    timer t(0, 100 msec)
    state latest
    
    reaction(startup){=
      self.latest = None
    =}
    reaction(vid) {=
    self.latest = vid.value 
    =}
    reaction(t)-> frame_fps{=
      if self.latest is not None:
        frame_fps.set(self.latest)
    =}
}

main reactor{
    dev = new DeviceReader()
    wheel = new steering_wheel()
    acc = new accelerator()
    brk = new brake()
    video = new webcam()
    face_detect = new FaceLandmark()
    dev.steer -> wheel.steer
    dev.brake -> brk.brake
    dev.throttle -> acc.accelerate
    dev.frame -> video.vid
    video.frame_fps -> face_detect.frame
}