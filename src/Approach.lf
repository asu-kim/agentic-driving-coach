target Python {keepalive: true}

preamble{=
    import requests
    import ollama
    import time
    import threading
    # import torch
    # from transformers import AutoTokenizer, AutoModelForCausalLM
    from enum import Enum
    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6
    
    
=}

reactor Driver{
    #has three ports which goes to the car reactor to calculate the speed every  100msec
    output steer
    output accelerator
    output brake

    state lines = []
    state idx = 0
    state loaded = False
    state done=False

    timer t(1000 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehavior.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip()!= "":
                        self.lines.append(int(ln.strip()))
                
            self.loaded = True
            print(f"Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake {=
        if self.done:
            return
        if not self.loaded or len(self.lines)==0:
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                request_stop()
                return
        if self.idx >= len(self.lines):
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                request_stop()
                return

        msg = self.lines[self.idx]
        print(f"Behavior: {msg}, Index: {self.idx}", flush=True)
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
            print(accelerator.value)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
            print(brake.value)
        self.idx += 1
    =}


}
reactor Car{
    input steer
    input accel
    input brk
    state acceleration_net
    state velocity_init = 10
    state dt = 0.1
    output velocity
    #acceleration_net is in m/s2

    reaction(accel, brk)->velocity{=

        amsg = accel.value
        bmsg = brk.value

        if bmsg == Brake(5).name:
            self.acceleration_net = (- 3.0)
        elif bmsg == Brake(6).name:
            self.acceleration_net = (- 9.0)
        elif amsg == Accelerate(1).name:
            self.acceleration_net = (-0.2)
        elif amsg == Accelerate(2).name:
            self.acceleration_net = (0.5)
        elif amsg == Accelerate(3).name:
            self.acceleration_net = (2.0)
        elif amsg == Accelerate(4).name:
            self.acceleration_net = (4.0)
        
        print(self.acceleration_net)

        
        v = self.velocity_init + self.acceleration_net * self.dt
        velocity.set(v)
        self.velocity_init = v
        print(f"velocity {v}")

    =}


}
reactor Environment{
    input velocity_ms
    state start_distance = 50
    state pos_stop_sign = 100
    output relative_distance
    output distance_travelled

    reaction(velocity_ms)->relative_distance, distance_travelled{=
        vn = velocity_ms.value
        d = self.start_distance + vn * 0.1
        self.start_distance = d
        self.pos_stop_sign -= (vn * 0.1)
        relative_distance.set(self.pos_stop_sign)
        distance_travelled.set(d)
    =}
}
reactor coach{
    input rel_distance
    input distance_moved

    reaction(startup){=
        print("[Coach] Startup: warming model", flush=True)
        ollama.chat(
        model="llama3.2:1b",
        messages=[{"role":"user","content":"warmup"}],
        options={"num_predict": 1}
        )
        def coach(user_prompt):
            start = time.time()
            r = ollama.chat(
                model="llama3.2:1b",
                #warmup the gpu kernals
                messages=[
                    {"role": "system", "content": "You are a driving coach. Be concise. Output ONLY one line."},
                    {"role": "user", "content": user_prompt}
                ],
                options={
                    "temperature": 0.0,
                    "num_predict": 24,
                }
            )
            end = time.time()
            msg = r["message"]["content"].strip()
            formatted = f"[Coach] {end - start:.3f}s | {msg}"
            return formatted
            # return r["message"]["content"].strip()
            # print(f"[Coach] {end - start:.3f}s | {r['message']['content']}", flush=True)
        self.coach = coach

        t = threading.Thread(target=coach, args=("Have a friendly conversation",), daemon=True)
        t.start()   
        #warmup the gpus
        coach("Have a friendly conversation")
        coach("motivate the drives")
    =}
    initial mode{
        state llm_response = ""
        reaction(rel_distance, distance_moved){=
        rd = rel_distance.value
        dm = distance_moved.value
        prompt = (
        f"Relative distance from the driver to stop sign: {rd:.2f} m.  Please give advice based on this changing relative distance value by informing the correct step "
        )
        print(prompt)
        self.llm_response = self.coach(prompt)
        print(self.llm_response)


    =}
    }
    
    // initial mode monitoring{}
    // mode warning{}
    // mode actuation{}

    
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    agent = new coach()

    d.accelerator -> c.accel
    d.brake -> c.brk
    d.steer -> c.steer

    c.velocity-> en.velocity_ms

    en.relative_distance -> agent.rel_distance
    en.distance_travelled -> agent.distance_moved
    
}