target Python {keepalive: true}

preamble{=
    import ollama
    import time
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9

    class Steer(Enum):
        Leftmost = 10
        Left = 11
        Rightmost = 12
        Right = 13
        Center = 14

    ALLOWED = {"NONE",  "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val, h_val, s_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:70b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|Message"
                        "TOKEN must be one of: NONE, WARNING, ACTUATE"
                        "Message must be one sentence, about about steering right + maintain speed."
                        "Use meters and m/s only."

                        "Rules for TOKEN:"
                        "if distance_to_maneuver is less than or equal to 25 and head position is not at right and steer position is not rightmost: TOKEN=ACTUATE\n"
                        "else if distance_to_maneuver is in between 50 to 60 and speed is less than 18 or greater than 18: TOKEN=WARNING\n"
                        "else if distance_to_maneuver greater than or equal to 80 and speed is less than 18 or greater than 18: TOKEN=WARNING\n"
                        "- else TOKEN=NONE\n"
                        "If TOKEN=NONE, output: NONE|\n"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": (
                        f"distance_to_maneuver={rd_val:.2f}m speed={v_val:.2f}m/s "
                        f"head={h_val} steer={s_val}"
                    ),
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1:
                tok = parts[0].upper().strip()
            if len(parts) == 2:
                msg = parts[1].strip()

       
        if tok not in ALLOWED:
            tok = "NONE"
            msg = ""

        msg = msg.replace("$", "").replace("`", "").strip().strip('"').strip("'")

        bad = ["token", "message", "rd=", "v=", "distance_to", "speed="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            
            if tok == "WARNING":
                msg = "Prepare to steer right soon. Maintain speed."
            elif tok == "ACTUATE":
                msg = "Steer right now. Maintain speed."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms

    def fallback_policy(rd_val, v_val, h_val, s_val):
        if rd_val <= 0.0:
            return "NONE", ""
        if rd_val <= 25.0 and (v_val > 18 or v_val< 18 ) and s_val != Steer(13).name :
            return "ACTUATE", "Steer right now. Maintain speed."
        if 50.0 < rd_val <= 60.0 and v_val > 18 or v_val< 18:
            return "WARNING", "Prepare to steer right soon. Maintain speed."
        if rd_val >= 80.0 and v_val > 18 or v_val< 18:
            return "NOTIFY", "Lane change ahead. Maintain speed."
        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state rows = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehaviorLane_beginner.txt", "r") as f:
                for ln in f.readlines():
                    ln = ln.strip()
                    if not ln:
                        continue
                    if ln.lower().startswith("accel"):
                        continue
                    parts = [p.strip() for p in ln.split(",")]
                    if len(parts) != 3:
                        continue
                    a = int(parts[0])
                    h = int(parts[1])
                    s = int(parts[2])
                    self.rows.append((a, h, s))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t) -> accelerator, brake, head, steer {=
        if self.done:
            return
        if not self.loaded or len(self.rows) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.rows):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        a, h, s = self.rows[self.idx]

        if a in [1, 2, 3, 4]:
            accelerator.set(Accelerate(a).name)
        elif a in [5, 6]:
            brake.set(Brake(a).name)

        if h in [7, 8, 9]:
            head.set(Head(h).name)

        if s in [10, 11, 12, 13, 14]:
            steer.set(Steer(s).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp
    input head

    state acceleration_net
    state velocity_init = 18.0

    output v
    output h
    output st

    reaction(accel, brk, ext_inp, head, steer)->v, h, st{=
        amsg = accel.value
        bmsg = brk.value
        hmsg = head.value
        smsg = steer.value

        
        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd
            elif cmd in [Steer(10).name, Steer(11).name, Steer(12).name, Steer(13).name, Steer(14).name]:
                smsg = cmd

       
        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -0.1
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 0.1
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 4.0
        else:
            self.acceleration_net = 0.0

        vel = self.velocity_init + self.acceleration_net * 0.1
        if vel < 0.0:
            vel = 0.0

        v.set(vel)
        h.set(hmsg)
        st.set(smsg)

        self.velocity_init = vel
    =}
}

reactor Environment{
    input v
    state lane_change_pos = 100.0
    state shifted = False

    output s

    reaction(v)->s{=
        vn = float(v.value)
        step = vn * 0.1

        if not self.shifted:
            self.lane_change_pos -= step
            if self.lane_change_pos <= 0.0:
                self.lane_change_pos = 0.0
                self.shifted = True
            s.set(self.lane_change_pos)
        else:
            s.set(0.0)
    =}
}

reactor LlmDecision {
    input s
    input v
    input h
    input st
    

    output dec
    output msg

    
    state done = False

   
    state last_dl_tok = ""
    state last_dl_msg = ""

    reaction(s, v, h, st) -> dec, msg {=
        rd_val = s.value if s.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
        h_val  = h.value if h.value is not None else Head(9).name
        s_val  = st.value if st.value is not None else Steer(14).name
        
 
        if self.done  or rd_val <= 0.0:
            dec.set("NONE")
            msg.set("")
            self.done = True
            return

     
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[head position]: {h_val}", flush=True)
        print(f"[steer position]: {s_val}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)

        tok, instruction, ms = run_llm_message(rd_val, v_val, h_val, s_val)

       
        self.check_deadline()

        dec.set(tok)
        msg.set(instruction)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {instruction}", flush=True)
    =}

    deadline(613 msec) {=
        rd_val = s.value if s.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
        h_val  = h.value if h.value is not None else Head(9).name
        s_val  = st.value if st.value is not None else Steer(14).name
       
       
        if self.done  or rd_val <= 0.0:
            dec.set("NONE")
            msg.set("")
            self.done = True
            return

        tok, instruction = fallback_policy(rd_val, v_val, h_val,s_val)

      
        if tok == self.last_dl_tok and instruction == self.last_dl_msg:
            return
        self.last_dl_tok = tok
        self.last_dl_msg = instruction

        dec.set(tok)
        msg.set(instruction)

   
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[head position]: {h_val}", flush=True)
        print(f"[steer position]: {s_val}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DEADLINE] fallback -> {tok} | {instruction}", flush=True)
    =}
}

reactor Agent {
  input dec
  input msg
  input s
  input v
  output extInp

  state last_printed = ""
  state last_warn_ns = -1000000000000


  initial mode monitoring {
    reaction(dec, msg, s, v) -> warning, actuate {=
      kw  = dec.value
      instruction = msg.value
      rd  = s.value if s.value is not None else 0.0
      vel   = v.value  if v.value is not None else 0.0
      throttle = 1000000000
      now_ns = lf.time.logical_elapsed()


      if kw == "ACTUATE" and rd > 0.0:
        if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
        actuate.set()
        return
      if kw == "WARNING":
        if (now_ns - self.last_warn_ns) >= throttle:
          if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
          self.last_warn_ns = now_ns
        warning.set()
        return
    =}
  }

  mode warning {
    reaction(dec, msg, s, v) -> monitoring, actuate {=
      kw  = dec.value
      instruction = msg.value
      rd  = s.value if s.value is not None else 0.0
      vel   = v.value  if v.value is not None else 0.0
      throttle = 1000000000
      now_ns = lf.time.logical_elapsed()


      if kw == "ACTUATE" and rd > 0.0:
        if instruction and instruction != self.last_printed:
          print(f"[VERBAL] {kw} | {instruction}", flush=True)
          self.last_printed = instruction
        actuate.set()
        return

      if kw == "NONE":
        monitoring.set()
        return

      if kw == "WARNING":
        if (now_ns - self.last_warn_ns) >= throttle:
          if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
          self.last_warn_ns = now_ns
        return
    =}
  }

  mode actuate {
    reaction(dec, s, v) -> extInp, monitoring {=
        kw = dec.value
        rd = s.value if s.value is not None else 0.0
        vel  = v.value  if v.value is not None else 0.0



        if kw != "ACTUATE" and rd > 0.0:

            monitoring.set()
            return

        if 0.0 < rd <= 25.0:
            extInp.set(Steer(12).name) 
            print(f"[ACTUATE] sent extInp={Steer(12).name}", flush=True)
        else:
            print("[ACTUATE] outside <=25m -> no action", flush=True)

        monitoring.set()
    =}
  }
}

reactor Coach{
    input s
    input v
    input h
    input st
    output extInp

    llm = new LlmDecision()
    Agent = new Agent()

    s -> llm.s
    v  -> llm.v
    h     -> llm.h
    st    -> llm.st

    llm.dec    -> Agent.dec
    llm.msg  -> Agent.msg
    s    -> Agent.s
    v               -> Agent.v

    Agent.extInp -> extInp
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel after 500 ms
    d.brake       -> c.brk after 500 ms
    d.steer       -> c.steer after 500 ms
    d.head        -> c.head after 500 ms

    c.v      -> en.v
    c.v       -> adc.v
    c.h  -> adc.h
    c.st -> adc.st

    en.s -> adc.s

    adc.extInp -> c.ext_inp after 200 ms
}