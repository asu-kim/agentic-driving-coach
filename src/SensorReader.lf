/*
* https://python-evdev.readthedocs.io/en/latest/apidoc.html#evdev.events.InputEvent to understand the evdev python library for linux
* e.type   # what kind of event
* e.code   # which control generated it
* e.value  # the current value
*/


target Python 

preamble {=
import threading
import time
from evdev import InputDevice, ecodes, list_devices
import cv2
import numpy as np
=}

reactor DeviceReader {
  output steer
  output throttle
  output brake
  output frame
  physical action sensor
  timer cam_timer(0, 100 msec)
  state cap
  state cam_ready = False


  reaction(startup) -> sensor {=
    def find_path():
      for p in list_devices():
        try:
          d = InputDevice(p)
          if "shanwan" in d.name.lower() and "gamepad" in d.name.lower():
            return p
        except Exception:
          pass
      return None

    path = find_path()
    if path is None:
      print("wheel device not found", flush=True)
      return
    #fr keeping the values to be in between [-1,1]
    def clamp(x, lo, hi):
        if x < lo:
            return lo
        elif x>hi:
            return hi
        else:
            return x
    #since the values are 0, 128, 255 we normalize
    def norm(dev, code, val):
      info = dev.absinfo(code)
      mini, maxi = info.min, info.max
      if maxi == mini:
        return 0.0
      result = (val - mini) / (maxi - mini)
      return result

    def reader(action, path):
      dev = InputDevice(path)
      print(f"The {dev.path} is the path and {dev.name} is the name of the device.\n")

      xinfo = dev.absinfo(ecodes.ABS_X)
      xmin, xmax = xinfo.min, xinfo.max

      for e in dev.read_loop():
        if e.type != ecodes.EV_ABS:
          continue

        if e.code == ecodes.ABS_X:
            #since the values are 0, 128, 255 we normalize
          s = ( 2 * (e.value - xmin) / (xmax - xmin) ) - 1.0
          s = float(clamp(s, -1.0, 1.0))
          action.schedule(0, ("steer", s))

        elif e.code == ecodes.ABS_BRAKE:
          b = float(clamp(norm(dev, ecodes.ABS_BRAKE, e.value), 0.0, 1.0))
          action.schedule(0, ("brake", b))

        elif e.code == ecodes.ABS_GAS:
            #this is for accelerator for this specific device
          tval = float(clamp(norm(dev, ecodes.ABS_GAS, e.value), 0.0, 1.0))
          action.schedule(0, ("throttle", tval))

    # added webcam reader as separate thread 
    # def webcam_reader(action):
    #   cap = cv2.VideoCapture(0, cv2.CAP_V4L2)
    #   if not cap.isOpened():
    #     print("cannot open camera 0")
    #     return

    #   count = 0
    #   print("Webcam started")
    #   while True:
    #     ok, img = cap.read()
    #     if ok:
    #       count += 1
    #       action.schedule(0, ("frame", img))
    #     time.sleep(0.1)

    t = threading.Thread(
            target=reader,
            args=(sensor, path),
            daemon=True
        )
    t.start()

    # cam_t = threading.Thread(
    #         target=webcam_reader,
    #         args=(sensor,),
    #         daemon=True
    #     )
    # cam_t.start()

    #we open the camera once to avoid segmentation faults 
    self.cap = cv2.VideoCapture(0, cv2.CAP_V4L2)
    if not self.cap.isOpened():
      print("Camera cannot be opened", flush=True)
      self.cam_ready = False
    else:
      cv2.setNumThreads(1)
      self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
      self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
      self.cap.set(cv2.CAP_PROP_FPS, 10)
      self.cam_ready = True
      print("Webcam opened", flush=True)

    print("The devices are connected\n")
  =}

  reaction(cam_timer) -> frame {=
    if not getattr(self, "cam_ready", False) or getattr(self, "cap", None) is None:
      return
    try:
      ok, img = self.cap.read()
      if ok and img is not None:
        img = np.ascontiguousarray(img)
        frame.set(img)
    except Exception as e:
      print("camera error reading the frames", e, flush=True)
  =}

  reaction(sensor) -> steer, brake, throttle{=
  tag, val = sensor.value

  if tag == "steer":
    steer.set(val)
  elif tag == "brake":
    brake.set(val)
  elif tag == "throttle":
    throttle.set(val)

=}

  reaction(shutdown) {=
      try:
        if getattr(self, "cap", None) is not None:
          self.cap.release()
      except Exception:
        pass
    =}
}