target Python {keepalive: true}

preamble{=
    import ollama
    import time
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9

    class Steer(Enum):
        Leftmost = 10
        Left = 11
        Rightmost = 12
        Right = 13
        Center = 14

    # Only keep these tokens
    ALLOWED = {"NONE", "NOTIFY", "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val, h_val, s_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:8b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|MSG\n"
                        "TOKEN must be one of: NONE, NOTIFY, WARNING, ACTUATE\n"
                        "MSG must be <= 12 words, about steering right + maintain speed.\n"
                        "Use meters and m/s only.\n"
                        "Do NOT include variable labels like rd=, v=, distance_to_*, speed=.\n"
                        "Rules for TOKEN:\n"
                        "- if distance_to_maneuver <= 25: TOKEN=ACTUATE\n"
                        "- else if 50 < distance_to_maneuver <= 60: TOKEN=WARNING\n"
                        "- else if distance_to_maneuver >= 80: TOKEN=NOTIFY\n"
                        "- else TOKEN=NONE\n"
                        "If TOKEN=NONE, output: NONE|\n"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": (
                        f"distance_to_maneuver={rd_val:.2f}m speed={v_val:.2f}m/s "
                        f"head={h_val} steer={s_val}"
                    ),
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1:
                tok = parts[0].upper().strip()
            if len(parts) == 2:
                msg = parts[1].strip()

        # Drop anything unexpected
        if tok not in ALLOWED:
            tok = "NONE"
            msg = ""

        msg = msg.replace("$", "").replace("`", "").strip().strip('"').strip("'")

        bad = ["token", "message", "rd=", "v=", "distance_to", "speed="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            if tok == "NOTIFY":
                msg = "Lane change ahead. Maintain speed."
            elif tok == "WARNING":
                msg = "Prepare to steer right soon. Maintain speed."
            elif tok == "ACTUATE":
                msg = "Steer right now. Maintain speed."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms

    def fallback_policy(rd_val, v_val):
        if rd_val <= 0.0:
            return "NONE", ""
        if rd_val <= 25.0:
            return "ACTUATE", "Steer right now. Maintain speed."
        if 50.0 < rd_val <= 60.0:
            return "WARNING", "Prepare to steer right soon. Maintain speed."
        if rd_val >= 80.0:
            return "NOTIFY", "Lane change ahead. Maintain speed."
        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state rows = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/daniel/furi/agentic-driving-coach/src/DriverBehaviorLane.txt", "r") as f:
                for ln in f.readlines():
                    ln = ln.strip()
                    if not ln:
                        continue
                    if ln.lower().startswith("accel"):
                        continue
                    parts = [p.strip() for p in ln.split(",")]
                    if len(parts) != 3:
                        continue
                    a = int(parts[0])
                    h = int(parts[1])
                    s = int(parts[2])
                    self.rows.append((a, h, s))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t) -> accelerator, brake, head, steer {=
        if self.done:
            return
        if not self.loaded or len(self.rows) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.rows):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        a, h, s = self.rows[self.idx]

        if a in [1, 2, 3, 4]:
            accelerator.set(Accelerate(a).name)
        elif a in [5, 6]:
            brake.set(Brake(a).name)

        if h in [7, 8, 9]:
            head.set(Head(h).name)

        if s in [10, 11, 12, 13, 14]:
            steer.set(Steer(s).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp
    input head

    state acceleration_net
    state velocity_init = 18.0

    output velocity
    output head_position
    output steer_position

    reaction(accel, brk, ext_inp, head, steer)->velocity, head_position, steer_position{=
        amsg = accel.value
        bmsg = brk.value
        hmsg = head.value
        smsg = steer.value

        
        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd
            elif cmd in [Steer(10).name, Steer(11).name, Steer(12).name, Steer(13).name, Steer(14).name]:
                smsg = cmd

       
        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -0.1
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 0.1
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 4.0
        else:
            self.acceleration_net = 0.0

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0

        velocity.set(v)
        head_position.set(hmsg)
        steer_position.set(smsg)

        self.velocity_init = v
    =}
}

reactor Environment{
    input velocity_ms
    state lane_change_pos = 100.0
    state shifted = False

    output relative_distance

    reaction(velocity_ms)->relative_distance{=
        vn = float(velocity_ms.value)
        step = vn * 0.1

        if not self.shifted:
            self.lane_change_pos -= step
            if self.lane_change_pos <= 0.0:
                self.lane_change_pos = 0.0
                self.shifted = True
            relative_distance.set(self.lane_change_pos)
        else:
            relative_distance.set(0.0)
    =}
}

reactor LlmDecision {
    input rd
    input v
    input h
    input s
    input shifted_flag   // NEW: true once lane change maneuver is done

    output decision
    output driver_msg

    
    state done = False

   
    state last_dl_tok = ""
    state last_dl_msg = ""

    reaction(rd, v, h, s, shifted_flag) -> decision, driver_msg {=
        rd_val = float(rd.value) if rd.value is not None else 0.0
        v_val  = float(v.value)  if v.value is not None else 0.0
        h_val  = h.value if h.value is not None else Head(9).name
        s_val  = s.value if s.value is not None else Steer(14).name
        passed = bool(shifted_flag.value) if shifted_flag.value is not None else False

 
        if self.done or passed or rd_val <= 0.0:
            decision.set("NONE")
            driver_msg.set("")
            self.done = True
            return

     
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[head position]: {h_val}", flush=True)
        print(f"[steer position]: {s_val}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)

        tok, msg, ms = run_llm_message(rd_val, v_val, h_val, s_val)

       
        self.check_deadline()

        decision.set(tok)
        driver_msg.set(msg)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {msg}", flush=True)
    =}

    deadline(1000 msec) {=
        rd_val = float(rd.value) if rd.value is not None else 0.0
        v_val  = float(v.value)  if v.value is not None else 0.0
        h_val  = h.value if h.value is not None else Head(9).name
        s_val  = s.value if s.value is not None else Steer(14).name
        passed = bool(shifted_flag.value) if shifted_flag.value is not None else False

       
        if self.done or passed or rd_val <= 0.0:
            decision.set("NONE")
            driver_msg.set("")
            self.done = True
            return

        tok, msg = fallback_policy(rd_val, v_val)

      
        if tok == self.last_dl_tok and msg == self.last_dl_msg:
            return
        self.last_dl_tok = tok
        self.last_dl_msg = msg

        decision.set(tok)
        driver_msg.set(msg)

        # -------- Debug prints (same block style) --------
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[head position]: {h_val}", flush=True)
        print(f"[steer position]: {s_val}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DEADLINE] fallback -> {tok} | {msg}", flush=True)
    =}
}

reactor Agent {
  input decision_in
  input driver_msg_in
  input rd_in
  input v_in
  output ext_inp_cmd

  state last_printed = ""

  initial mode monitoring {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> warning, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value) if rd_in.value is not None else 0.0
      v   = float(v_in.value)  if v_in.value is not None else 0.0

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "WARNING" or kw == "NOTIFY":
        warning.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> monitoring, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value) if rd_in.value is not None else 0.0
      v   = float(v_in.value)  if v_in.value is not None else 0.0

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "NONE":
        monitoring.set()
    =}
  }

  mode actuate {
    reaction(decision_in, rd_in, v_in) -> ext_inp_cmd, monitoring {=
        kw = decision_in.value
        rd = float(rd_in.value) if rd_in.value is not None else 0.0
        v  = float(v_in.value)  if v_in.value is not None else 0.0

        print(f"[ACTUATE] rd={rd:.2f}  v={v:.2f}  kw={kw}", flush=True)

        if kw != "ACTUATE" and rd > 0.0:
            print("[ACTUATE] exit (kw != ACTUATE)", flush=True)
            monitoring.set()
            return

        if 0.0 < rd <= 25.0:
            ext_inp_cmd.set(Steer(12).name) 
            print(f"[ACTUATE] sent ext_inp_cmd={Steer(12).name}", flush=True)
        else:
            print("[ACTUATE] outside <=25m -> no action", flush=True)

        monitoring.set()
    =}
  }
}

reactor Coach{
    input rel_distance
    input velocity_ms
    input head_pos
    input steer_pos
    output ext_inp_cmd

    llm = new LlmDecision()
    Agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v
    head_pos     -> llm.h
    steer_pos    -> llm.s

    llm.decision    -> Agent.decision_in
    llm.driver_msg  -> Agent.driver_msg_in
    rel_distance    -> Agent.rd_in
    velocity_ms     -> Agent.v_in

    Agent.ext_inp_cmd -> ext_inp_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel after 500 ms
    d.brake       -> c.brk after 500 ms
    d.steer       -> c.steer after 500 ms
    d.head        -> c.head after 500 ms

    c.velocity       -> en.velocity_ms
    c.velocity       -> adc.velocity_ms
    c.head_position  -> adc.head_pos
    c.steer_position -> adc.steer_pos

    en.relative_distance -> adc.rel_distance

    adc.ext_inp_cmd -> c.ext_inp after 200 ms
}