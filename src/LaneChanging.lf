reactor LlmDecision {
    input rd
    input v
    input h
    input s

    output decision
    output driver_msg

    reaction(rd, v, h, s) -> decision, driver_msg {=
        rd_val = rd.value if rd.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
        h_val  = h.value  if h.value is not None else Head(9).name
        s_val  = s.value  if s.value is not None else Steer(14).name

        tok, msg, ms = run_llm_message(rd_val, v_val, h_val, s_val)

        self.check_deadline()

        decision.set(tok)
        driver_msg.set(msg)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {msg}", flush=True)
    =}
    deadline(1000 msec) {=
        rd_val = rd.value if rd.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0

        tok = "NONE"
        msg = ""

        if rd_val <= 25 and v_val > 11:
            tok = "ACTUATE"
            msg = "Steer left now and maintain speed."
        elif 50 < rd_val <= 60:
            tok = "WARNING"
            msg = "Prepare to steer left soon and maintain speed."
        elif rd_val >= 80:
            tok = "NOTIFY"
            msg = "Lane change ahead. Maintain speed."

        decision.set(tok)
        driver_msg.set(msg)

        print(f"[DEADLINE] fallback -> {tok} | {msg}", flush=True)
    =}
}


reactor Agent {
  input decision_in
  input driver_msg_in
  input rd_in
  input v_in
  output ext_inp_cmd

  state last_printed = ""
  state act_cnt = 0

  initial mode monitoring {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> warning, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = rd_in.value
      v   = v_in.value

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "WARNING" or kw == "ALERT" or kw == "NOTIFY":
        warning.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> monitoring, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = rd_in.value
      v   = v_in.value

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "NONE":
        monitoring.set()
    =}
  }

  mode actuate {
    reaction(decision_in, rd_in, v_in) -> ext_inp_cmd, monitoring {=
        kw = decision_in.value
        rd = rd_in.value
        v  = v_in.value

       
        if kw != "ACTUATE" and rd > 0.0:
            monitoring.set()
            return

        
        if rd >= 60:
            if v < 18:
                ext_inp_cmd.set(Accelerate(3).name)
        elif 50 < rd < 60:
            if v < 18:
                ext_inp_cmd.set(Accelerate(2).name)
            
        elif rd <= 25:
            ext_inp_cmd.set(Steer(11).name)

        monitoring.set()
    =}
}
}

reactor Coach{
    input rel_distance
    input velocity_ms
    input head_pos
    input steer_pos
    output ext_inp_cmd

    llm = new LlmDecision()
    Agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v

    llm.decision -> Agent.decision_in
    llm.driver_msg -> Agent.driver_msg_in

    rel_distance   -> Agent.rd_in
    velocity_ms    -> Agent.v_in
    head_pos -> llm.h
    steer_pos -> llm.s

    Agent.ext_inp_cmd -> ext_inp_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel
    d.brake -> c.brk
    d.steer -> c.steer
    d.head -> c.head

    c.velocity -> en.velocity_ms
    c.velocity -> adc.velocity_ms
    c.head_position -> adc.head_pos
    c.steer_position -> adc.steer_pos

    en.relative_distance -> adc.rel_distance


    adc.ext_inp_cmd -> c.ext_inp after 1 nsec
}