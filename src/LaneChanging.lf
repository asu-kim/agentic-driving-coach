preamble{=
    import re
    import ollama
    import time
    import threading
    from enum import Enum
    from queue import Queue, Empty

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9
    class Steer(Enum):
        Leftmost = 10
        Left = 11
        Rightmost = 12
        Right = 13
        Center = 14

    ALLOWED = {"NONE", "NOTIFY", "ALERT", "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val, h_val, s_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:8b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|MSG\n"
                        "TOKEN must be one of: NONE, NOTIFY, WARNING, ALERT, ACTUATE\n"
                        "MSG must be one sentence.\n"
                        "MSG must be about changing to the left lane (steer left) and maintaining speed.\n"
                        "Use meters and m/s only. Do not use km/h.\n"
                        "Do not include variable labels like rd= or v=.\n"
                        "Rules for TOKEN:\n"
                        "- if distance_to_maneuver <= 25 and speed > 11: TOKEN=ACTUATE\n"
                        "- else if 50 < distance_to_maneuver <= 60: TOKEN=WARNING\n"
                        "- else if distance_to_maneuver >= 80: TOKEN=NOTIFY\n"
                        "- else TOKEN=NONE\n"
                        "If TOKEN=NONE, output: NONE|\n"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": (
                        f"distance_to_maneuver={rd_val:.2f}m "
                        f"speed={v_val:.2f}m/s head={h_val} steer={s_val}"
                    ),
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1 and parts[0].upper() in ALLOWED:
                tok = parts[0].upper()
            if len(parts) == 2:
                msg = parts[1]

        msg = msg.replace("$", "").replace("`", "")
        msg = msg.strip('"').strip("'").strip()

        bad = ["token", "message", "position", "velocity", "rd=", "v="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            if tok == "NOTIFY":
                msg = "Lane change ahead."
            elif tok == "ALERT":
                msg = "Be ready to steer left."
            elif tok == "WARNING":
                msg = "Prepare to steer left soon and maintain speed."
            elif tok == "ACTUATE":
                msg = "Steer left now and maintain speed."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms

    def fallback_policy(rd_val, v_val):
        if rd_val <= 0.0:
            return "NONE", ""
        if rd_val <= 25 and v_val > 11:
            return "ACTUATE", "Steer left now and maintain speed."
        if 50 < rd_val <= 60:
            return "WARNING", "Prepare to steer left soon and maintain speed."
        if rd_val >= 80:
            return "NOTIFY", "Lane change ahead."
        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state rows = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehaviorLane.txt", "r") as f:
                for ln in f.readlines():
                    ln = ln.strip()
                    if not ln:
                        continue
                    if ln.lower().startswith("accel"):
                        continue
                    parts = [p.strip() for p in ln.split(",")]
                    if len(parts) != 3:
                        continue
                    a = int(parts[0])
                    h = int(parts[1])
                    s = int(parts[2])
                    self.rows.append((a, h, s))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t) -> accelerator, brake, head, steer {=
        if self.done:
            return
        if not self.loaded or len(self.rows) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.rows):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        a, h, s = self.rows[self.idx]

        if a in [1, 2, 3, 4]:
            accelerator.set(Accelerate(a).name)
        elif a in [5, 6]:
            brake.set(Brake(a).name)

        if h in [7, 8, 9]:
            head.set(Head(h).name)

        if s in [10, 11, 12, 13, 14]:
            steer.set(Steer(s).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp
    input head

    state acceleration_net
    state velocity_init = 18.0
    // state dist_init = 0.0
    // state head_pos = ""
    // state steer_pos

    output velocity
    // output dist_trav
    output head_position
    output steer_position


    reaction(accel, brk, ext_inp, head, steer)->velocity, head_position, steer_position{=
        amsg = accel.value
        bmsg = brk.value
        hmsg = head.value
        smsg = steer.value

        # if hmsg == Head(7).name:
        #     self.head_pos = "Left"
        # elif hmsg == Head(8).name:
        #     self.head_pos = "Right"
        # elif hmsg == Head(9).name:
        #     self.head_pos = "Center"


        # ext_inp can be either a Brake name or an Accelerate name
        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd
            elif cmd in [Steer(10).name, Steer(11).name, Steer(12).name, Steer(13).name, Steer(14).name]:
                smsg = cmd

        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -1.0
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 5.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 10.0
        else:
            self.acceleration_net = 0.0

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0

        # d = self.dist_init + v * 0.1

        velocity.set(v)
        # dist_trav.set(d)
        head_position.set(hmsg)
        steer_position.set(smsg)

        self.velocity_init = v
        # self.dist_init = d
    =}
}

reactor Environment{
    input velocity_ms
    state lane_change_pos = 100.0
    state shifted = False
    
    output relative_distance
 

    reaction(velocity_ms)->relative_distance{=
        vn = velocity_ms.value
        step = vn * 0.1

        if not self.shifted:
            self.lane_change_pos -= step
            if self.lane_change_pos <= 0.0:
                self.lane_change_pos = 0.0
                self.shifted = True
            relative_distance.set(self.lane_change_pos)
        else:
            relative_distance.set(0.0)
           
    =}
}

