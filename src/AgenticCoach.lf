target Python {keepalive: true, DNET: false, coordination-options: {
    advance-message-interval: 10 msec
  }}

import Inputs from "Inputs.lf"
import Driver from "DriverInput.lf"

preamble {=
    import os
    import threading
    import time
    # import torch
    # from transformers import AutoTokenizer, AutoModelForCausalLM, BitsAndBytesConfig
=}

reactor RoadSign (object_detected="stop sign", start_distance=200.0, step=10.0){
    output status
    output label
    output distance

    state dis = start_distance

    timer detect(0, 500 msec)

    reaction(detect) -> label, distance, status {=
        label.set(self.object_detected)
        distance.set(self.dis)

      
        if self.dis > 0.0:
            if self.dis <= 40.0:
                status.set("stop_detected")
            else:
                status.set("nearing_sign")
        else:

            status.set("passed_sign")


        self.dis = self.dis - self.step
    =}
}

reactor AgenticLlm(use_llm=False){
    input steer_msg
    input accel_msg
    input brake_msg
    input head_msg
    input eye_msg
    input speed
    input accelaration_mps2
    input pedal_st

    input driver_msg
    output feedback

    input sign_status
    input sign_distance

    state last_steer_msg = ""
    state last_accel_msg = ""
    state last_brake_msg = ""
    state last_head_msg = ""
    state last_eye_msg = ""
    state last_driver_msg = ""
    state warn = False

    state last_sign = "no_sign"
    state last_sign_distance = -1.0
    state last_speed = 0.0
    state last_acceleration = 0.0
    state last_pedal_pos = ""


    timer check(0, 100msec)

    reaction(startup){=
        if not self.use_llm:
            print("LLM disabled")
            return
            # print("[LlmA] Loading 70B", flush=True)
            # os.environ["TRANSFORMERS_OFFLINE"] = "1"
            # self.has_cuda = torch.cuda.is_available()
            # self.dtype = torch.bfloat16 if self.has_cuda else torch.float32

            # #change this to the locally downloaded model
            # model_id = "path/Llama-2-70b-chat-hf"
            # #This is a pretrained tokenizer from hugging face.
            # self.tokenizer_a = AutoTokenizer.from_pretrained(
            #     model_id, use_fast=True, local_files_only=True
            # )
            # if self.tokenizer_a.pad_token_id is None:
            #     self.tokenizer_a.pad_token = self.tokenizer_a.eos_token

            # #Here we map the device to the GPU. 
            # common_a = dict(
            #     device_map="auto" if self.has_cuda else None,
            #     torch_dtype=self.dtype,
            #     low_cpu_mem_usage=True,
            #     local_files_only=True,
            # )
            # #The 4 bit quantization will be selected if the device supports it.
            # try:
            #     import bitsandbytes as bnb
            #     common_a["quantization_config"] = BitsAndBytesConfig(
            #         load_in_4bit=True,
            #         bnb_4bit_quant_type="nf4",
            #         bnb_4bit_use_double_quant=True,
            #         bnb_4bit_compute_dtype=self.dtype,
            #     )
            # except Exception:
            #     pass
            
            # #Here we load the model and map it to the device.
            # self.model_a = AutoModelForCausalLM.from_pretrained(model_id, **common_a)
            # self.model_a.eval()

            # #Text-generation module. 
            # self.GEN_A = dict(
            #     max_new_tokens=24,
            #     do_sample=False,
            #     eos_token_id=self.tokenizer_a.eos_token_id,
            #     pad_token_id=self.tokenizer_a.pad_token_id,
            # )

            # print("[LlmA] Ready.", flush=True)
  =}

    reaction(steer_msg, accel_msg, brake_msg, head_msg, eye_msg, speed, accelaration_mps2, pedal_st){=
        if steer_msg.is_present:
            self.last_steer_msg = steer_msg.value
        if accel_msg.is_present:
            self.last_accel_msg = accel_msg.value
        if brake_msg.is_present:
            self.last_brake_msg = brake_msg.value
        if head_msg.is_present:
            self.last_head_msg = head_msg.value
        if eye_msg.is_present:
            self.last_eye_msg = eye_msg.value
        if speed.is_present:
            self.last_speed = float(speed.value)   
        if accelaration_mps2.is_present:
            self.last_acceleration = float(accelaration_mps2.value) 
        if pedal_st.is_present:
            self.last_pedal_pos = pedal_st.value
    =}

    reaction(driver_msg){=
        if driver_msg.is_present:
            self.last_driver_msg = driver_msg.value
    =}

    reaction (sign_status, sign_distance){=
        if sign_status.is_present:
            self.last_sign = sign_status.value
        if sign_distance.is_present:
            self.last_sign_distance = sign_distance.value
    =}


    initial mode monitoring{
        reaction(check)-> warning{=
            check_status = self.last_sign.lower()
            check_distance = float(self.last_sign_distance)

            print(f"[DBG] status={check_status} dist={check_distance:.1f} speed={self.last_speed:.1f} pedal={self.last_pedal_pos}", flush=True)
            if check_status in ("stop_detected", "nearing_sign"):
                if 38.0 <= check_distance <= 42.0 and self.last_speed > 24.0:
                    print("mode warning")
                    warning.set()
        =}
    }

    mode warning{
        reaction(check)-> monitoring, actuation, feedback  {=
            check_status = self.last_sign.lower()
            check_distance = float(self.last_sign_distance)

            if check_status == "no_sign" or check_distance <= 0.0:
                print("\nNo signs hence switching to monitoring\n")
                monitoring.set()
                return
            if 20.0 <= check_distance <= 25.0 and self.last_speed >= 15.0:
                print("\n Taking control: actuation\n")
                actuation.set()
                return


            feedback.set(
                f"WARNING: stop sign ahead ({check_distance:.1f}m). "
                f"Speed {self.last_speed:.1f} km/h. Start slowing down."
            )
            print(f"WARNING (dist={check_distance:.2f}, speed={self.last_speed:.1f})")
        =}
    }

    mode actuation{
        reaction(check) -> feedback {=
            sdist = float(self.last_sign_distance)
            feedback.set(
                f"ACTUATE: Brake now. Stop sign in {sdist:.1f}m. "
                f"Current speed {self.last_speed:.1f} km/h."
            )
        =}
    }
}

// federated reactor AgenticCoach{
federated reactor AgenticCoach at 10.218.100.78{
    sensor_inputs = new Inputs()
    agent = new AgenticLlm()
    driver = new Driver()
    sign = new RoadSign()

    sensor_inputs.steer_msg -> agent.steer_msg
    sensor_inputs.accel_msg -> agent.accel_msg
    sensor_inputs.brake_msg -> agent.brake_msg
    sensor_inputs.head_msg  -> agent.head_msg
    sensor_inputs.eye_msg   -> agent.eye_msg
    sensor_inputs.speed -> agent.speed
    sensor_inputs.acceleration_mps2 -> agent.accelaration_mps2
    sensor_inputs.pedal_position -> agent.pedal_st

    sign.status -> agent.sign_status
    sign.distance -> agent.sign_distance

    driver.questions -> agent.driver_msg
    agent.feedback -> driver.feedback

}
