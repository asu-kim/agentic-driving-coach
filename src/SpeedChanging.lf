target Python {keepalive: true}

preamble{=
    import ollama
    import time
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9
    class Steer(Enum):
        Leftmost = 10
        Left = 11
        Rightmost = 12
        Right = 13
        Center = 14
    
    ALLOWED = {"NONE", "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:70b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|Message"
                        "TOKEN must be one of: NONE, WARNING, ACTUATE"
                        "Message must be one sentence, about speed change only."
                        "Use meters and m/s only."

                        "Rules for TOKEN:"
                        "if distance_to_sign is lesser than or equal to 25 and speed is greater than 12 or lesser than 11 then TOKEN=ACTUATE\n"
                        "else if distance_to_stop lies in between 50 to 60 and speed is in between 15 to 13 then TOKEN=WARNING"
                        "else if distance_to_sign is greater than 80 and speed is not in between 18 to 16 then TOKEN=WARNING\n"
                        "else TOKEN=NONE\n"

                        "If TOKEN=NONE, output: NONE|\n"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": f"distance_to_sign={rd_val:.2f}m speed={v_val:.2f}m/s",
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1:
                tok = parts[0].upper().strip()
            if len(parts) == 2:
                msg = parts[1].strip()

        
        if tok not in ALLOWED:
            tok = "NONE"
            msg = ""

        msg = msg.replace("$", "").replace("`", "").strip().strip('"').strip("'")

        bad = ["token", "message", "rd=", "v=", "distance_to", "speed="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            
            if tok == "WARNING":
                msg = "Slow down to 11 m/s."
            elif tok == "ACTUATE":
                msg = "Brake now."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms
    
    def fallback_policy(rd_val, v_val):
        if rd_val <= 0.0:
            return "NONE", ""

        if rd_val <= 25 and (v_val>12 or v_val<11):
            return "ACTUATE", "Brake now."

        if rd_val >= 80.0 and (v_val > 18 or v_val<16) :
            return "WARNING", "Speed limit change ahead."
        if 50.0 < rd_val <= 60.0 and (v_val > 15 or v_val<13):
            return "WARNING", "Slow down to 11 m/s."

        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state lines = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehaviorSpeed_beginner.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip() != "":
                        self.lines.append(int(ln.strip()))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake, head {=
        if self.done:
            return
        if not self.loaded or len(self.lines) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.lines):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        msg = self.lines[self.idx]
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
        elif msg in [7, 8, 9]:
            head.set(Head(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp
    input head

    state acceleration_net
    state velocity_init = 18.0
    state dist_init = 0.0

    output v
    

    reaction(accel, brk, ext_inp)->v{=
        amsg = accel.value
        bmsg = brk.value

        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd

        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -0.1
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 0.1
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 4.0
        else:
            self.acceleration_net = 0.0

        vel = self.velocity_init + self.acceleration_net * 0.1
        if vel < 0.0:
            vel = 0.0



        v.set(vel)


        self.velocity_init = vel

    =}
}

reactor Environment{
    input v
    state speed_change_pos = 100.0
    state passed = False
    state after_m = 0.0

    output s
   

    reaction(v)->s{=
        vn = float(v.value)
        step = vn * 0.1

        if not self.passed:
            self.speed_change_pos -= step
            if self.speed_change_pos <= 0.0:
                self.speed_change_pos = 0.0
                self.passed = True
                self.after_m = 0.0

            s.set(self.speed_change_pos)
            
        else:
            self.after_m += step
            s.set(0.0)
            
    =}
}

reactor LlmDecision {
    input s
    input v
    

    output dec
    output msg

    state last_dl_tok = ""
    state last_dl_msg = ""

    reaction(s, v) -> dec, msg {=
        
        rd_val = s.value         if s.value is not None else 0.0
        v_val  = v.value          if v.value is not None else 0.0

       
        if rd_val <= 0.0:
            dec.set("NONE")
            msg.set("")
            return

        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)

        tok, instruction, ms = run_llm_message(rd_val, v_val)

      
        self.check_deadline()

        dec.set(tok)
        msg.set(instruction)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {instruction}", flush=True)
    =}

    deadline(613 msec) {=
        rd_val = s.value if s.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
       

        if rd_val <= 0.0:
            tok, instruction = "NONE", ""
        else:
            tok, instruction = fallback_policy(rd_val, v_val)

       
        if tok == self.last_dl_tok and instruction == self.last_dl_msg:
            return
        self.last_dl_tok = tok
        self.last_dl_msg = instruction

        dec.set(tok)
        msg.set(instruction)
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)
        print(f"[DEADLINE] fallback -> {tok} | {instruction}", flush=True)
    =}
}

reactor Agent {
  input dec
  input msg
  input s
  input v
  output expInp

  state last_printed = ""
  state last_warn_ns = -1000000000000

  initial mode monitoring {
    reaction(dec, msg, s, v) -> warning, actuate {=
      throttle = 1000000000
      kw  = dec.value
      instruction = msg.value
      rd  = s.value
      vel   = v.value
      now_ns = lf.time.logical_elapsed()

      

      if kw == "ACTUATE" and rd > 0.0:
        if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
        actuate.set()
        return
      if kw == "WARNING":
        if (now_ns - self.last_warn_ns) >= throttle:
          if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
          self.last_warn_ns = now_ns
        warning.set()
        return
    =}
  }

  mode warning {
    reaction(dec, msg, s, v) -> monitoring, actuate {=
      kw  = dec.value
      instruction = msg.value
      rd  = s.value
      vel   = v.value
      throttle = 1000000000
      now_ns = lf.time.logical_elapsed()


      if kw == "ACTUATE" and rd > 0.0:
        if instruction and instruction != self.last_printed:
          print(f"[VERBAL] {kw} | {instruction}", flush=True)
          self.last_printed = instruction
        actuate.set()
        return

      if kw == "NONE":
        monitoring.set()
        return

      if kw == "WARNING":
        if (now_ns - self.last_warn_ns) >= throttle:
          if instruction and instruction != self.last_printed:
            print(f"[VERBAL] {kw} | {instruction}", flush=True)
            self.last_printed = instruction
          self.last_warn_ns = now_ns
        return
    =}
  }

  mode actuate {
    reaction(dec, s, v) -> expInp, monitoring {=
        kw = dec.value
        rd = s.value if s.value is not None else 0.0
        vel  = v.value  if v.value is not None else 0.0

        TARGET = 11.0
        HI = TARGET + 0.5
        LO = TARGET - 0.5



        
        if kw not in ["WARNING", "ACTUATE"]:

            monitoring.set()
            return

       
        if 50.0 < rd <= 60.0:
            print("[ACTUATE] Control zone 50–60m", flush=True)

            if vel > HI:
                print("[ACTUATE] Gentle brake -> reduce speed", flush=True)
                expInp.set(Brake(5).name)

            elif vel < LO:
                print("[ACTUATE] Mild accel -> increase speed", flush=True)
                expInp.set(Accelerate(3).name)

            else:
                print("[ACTUATE] Speed in band -> cruise", flush=True)
                expInp.set(Accelerate(2).name)

            monitoring.set()
            return

        
        if rd <= 25.0:
            print("[ACTUATE] Near sign zone <=25m", flush=True)

            if vel > HI:
                print("[ACTUATE] Strong brake", flush=True)
                expInp.set(Brake(6).name)
            else:
                print("[ACTUATE] Mild brake", flush=True)
                expInp.set(Brake(5).name)

            monitoring.set()
            return

        print("[ACTUATE] Outside control zone -> no action", flush=True)
        monitoring.set()
    =}
}   
}

reactor Coach{
    input s
    input v
    
    output expInp

    llm = new LlmDecision()
    Agent = new Agent()

    s -> llm.s
    v  -> llm.v
   

    llm.dec -> Agent.dec
    llm.msg -> Agent.msg

    s   -> Agent.s
    v    -> Agent.v

    Agent.expInp -> expInp
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel after 500 ms
    d.brake -> c.brk after 500 ms
    d.steer -> c.steer after 500 ms
    d.head-> c.head after 500 ms

    c.v -> en.v
    c.v -> adc.v

    
    en.s -> adc.s

    adc.expInp -> c.ext_inp after 200 ms
}