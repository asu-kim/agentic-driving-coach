target Python {keepalive: true}

preamble{=
    import ollama
    import time
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9

    # Only keep these tokens
    ALLOWED = {"NONE", "NOTIFY", "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:8b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|MSG\n"
                        "TOKEN must be one of: NONE, NOTIFY, WARNING, ACTUATE\n"
                        "MSG must be <= 12 words, about speed only.\n"
                        "Use meters and m/s only.\n"
                        "Rules for TOKEN:\n"
                        "- if distance_to_sign <= 25 and speed > 11: TOKEN=ACTUATE\n"
                        "- else if 50 < distance_to_sign <= 60: TOKEN=WARNING\n"
                        "- else if distance_to_sign >= 80: TOKEN=NOTIFY\n"
                        "- else TOKEN=NONE\n"
                        "If TOKEN=NONE, output: NONE|\n"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": f"distance_to_sign={rd_val:.2f}m speed={v_val:.2f}m/s",
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1:
                tok = parts[0].upper().strip()
            if len(parts) == 2:
                msg = parts[1].strip()

        # If model outputs something unexpected (like ALERT), drop it
        if tok not in ALLOWED:
            tok = "NONE"
            msg = ""

        msg = msg.replace("$", "").replace("`", "").strip().strip('"').strip("'")

        bad = ["token", "message", "rd=", "v=", "distance_to", "speed="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            if tok == "NOTIFY":
                msg = "Speed limit change ahead."
            elif tok == "WARNING":
                msg = "Slow down to 11 m/s."
            elif tok == "ACTUATE":
                msg = "Brake now."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms
    def brake_distance(v, a=9.0, buf=1.0):
        
        v_target = 11.0
        if v <= v_target:
            return 0.0
      
        return (v*v - v_target*v_target) / (2.0*a) + buf
    def fallback_policy(rd_val, v_val):
        if rd_val <= 0.0:
            return "NONE", ""

       
        if rd_val <= brake_distance(v_val, a=9.0, buf=1.0):
            return "ACTUATE", "Brake now."

        if rd_val >= 80.0:
            return "NOTIFY", "Speed limit change ahead."
        if 50.0 < rd_val <= 60.0 and v_val > 11.0:
            return "WARNING", "Slow down to 11 m/s."

        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state lines = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/daniel/furi/agentic-driving-coach/src/DriverBehaviorSpeed.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip() != "":
                        self.lines.append(int(ln.strip()))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake, head {=
        if self.done:
            return
        if not self.loaded or len(self.lines) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.lines):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        msg = self.lines[self.idx]
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
        elif msg in [7, 8, 9]:
            head.set(Head(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp

    state acceleration_net
    state velocity_init = 18.0
    state dist_init = 0.0

    output velocity
    output dist_trav

    reaction(accel, brk, ext_inp)->velocity, dist_trav{=
        amsg = accel.value
        bmsg = brk.value

        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd

        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -0.1
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 0.1
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 4.0
        else:
            self.acceleration_net = 0.0

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0

        d = self.dist_init + v * 0.1

        velocity.set(v)
        dist_trav.set(d)

        self.velocity_init = v
        self.dist_init = d
    =}
}

reactor Environment{
    input velocity_ms
    state speed_change_pos = 100.0
    state passed = False
    state after_m = 0.0

    output relative_distance
    output dist_aft_speed

    reaction(velocity_ms)->relative_distance, dist_aft_speed{=
        vn = float(velocity_ms.value)
        step = vn * 0.1

        if not self.passed:
            self.speed_change_pos -= step
            if self.speed_change_pos <= 0.0:
                self.speed_change_pos = 0.0
                self.passed = True
                self.after_m = 0.0

            relative_distance.set(self.speed_change_pos)
            dist_aft_speed.set(0.0)
        else:
            self.after_m += step
            relative_distance.set(0.0)
            dist_aft_speed.set(self.after_m)
    =}
}

reactor LlmDecision {
    input rd
    input v
    input dis_aft_sp

    output decision
    output driver_msg

    state last_dl_tok = ""
    state last_dl_msg = ""

    reaction(rd, v, dis_aft_sp) -> decision, driver_msg {=
        d_val  = dis_aft_sp.value if dis_aft_sp.value is not None else 0.0
        rd_val = rd.value         if rd.value is not None else 0.0
        v_val  = v.value          if v.value is not None else 0.0

       
        if d_val > 0.0 or rd_val <= 0.0:
            decision.set("NONE")
            driver_msg.set("")
            return

        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DISTANCE after speed]: {d_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)

        tok, msg, ms = run_llm_message(rd_val, v_val)

      
        self.check_deadline()

        decision.set(tok)
        driver_msg.set(msg)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {msg}", flush=True)
    =}

    deadline(300 msec) {=
        rd_val = rd.value if rd.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
        d_val  = dis_aft_sp.value if dis_aft_sp.value is not None else 0.0

        if d_val > 0.0 or rd_val <= 0.0:
            tok, msg = "NONE", ""
        else:
            tok, msg = fallback_policy(rd_val, v_val)

        # avoid repeated identical deadline spam
        if tok == self.last_dl_tok and msg == self.last_dl_msg:
            return
        self.last_dl_tok = tok
        self.last_dl_msg = msg

        decision.set(tok)
        driver_msg.set(msg)
        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DISTANCE after speed]: {d_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DEADLINE] fallback -> {tok} | {msg}", flush=True)
    =}
}

reactor Agent {
  input decision_in
  input driver_msg_in
  input rd_in
  input v_in
  output ext_inp_cmd

  state last_printed = ""

  initial mode monitoring {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> warning, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = rd_in.value
      v   = v_in.value

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "WARNING" or kw == "NOTIFY":
        warning.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> monitoring, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = rd_in.value
      v   = v_in.value

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "NONE":
        monitoring.set()
    =}
  }

  mode actuate {
    reaction(decision_in, rd_in, v_in) -> ext_inp_cmd, monitoring {=
        kw = decision_in.value
        rd = float(rd_in.value) if rd_in.value is not None else 0.0
        v  = float(v_in.value)  if v_in.value is not None else 0.0

        TARGET = 11.0
        HI = TARGET + 0.5
        LO = TARGET - 0.5

        print(f"[ACTUATE] rd={rd:.2f}  v={v:.2f}", flush=True)

        
        if kw not in ["WARNING", "ACTUATE"]:
            print("[ACTUATE] No control (kw not WARNING/ACTUATE)", flush=True)
            monitoring.set()
            return

       
        if 50.0 < rd <= 60.0:
            print("[ACTUATE] Control zone 50–60m", flush=True)

            if v > HI:
                print("[ACTUATE] Gentle brake -> reduce speed", flush=True)
                ext_inp_cmd.set(Brake(5).name)

            elif v < LO:
                print("[ACTUATE] Mild accel -> increase speed", flush=True)
                ext_inp_cmd.set(Accelerate(3).name)

            else:
                print("[ACTUATE] Speed in band -> cruise", flush=True)
                ext_inp_cmd.set(Accelerate(2).name)

            monitoring.set()
            return

        
        if rd <= 25.0:
            print("[ACTUATE] Near sign zone <=25m", flush=True)

            if v > HI:
                print("[ACTUATE] Strong brake", flush=True)
                ext_inp_cmd.set(Brake(6).name)
            else:
                print("[ACTUATE] Mild brake / settle", flush=True)
                ext_inp_cmd.set(Brake(5).name)

            monitoring.set()
            return

        print("[ACTUATE] Outside control zone -> no action", flush=True)
        monitoring.set()
    =}
}   
}

reactor Coach{
    input rel_distance
    input velocity_ms
    input dist_aft_speed
    output ext_inp_cmd

    llm = new LlmDecision()
    Agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v
    dist_aft_speed -> llm.dis_aft_sp

    llm.decision -> Agent.decision_in
    llm.driver_msg -> Agent.driver_msg_in

    rel_distance   -> Agent.rd_in
    velocity_ms    -> Agent.v_in

    Agent.ext_inp_cmd -> ext_inp_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel after 500 ms
    d.brake -> c.brk after 500 ms
    d.steer -> c.steer after 500 ms

    c.velocity -> en.velocity_ms
    c.velocity -> adc.velocity_ms

    en.dist_aft_speed -> adc.dist_aft_speed
    en.relative_distance -> adc.rel_distance

    adc.ext_inp_cmd -> c.ext_inp after 200 ms
}