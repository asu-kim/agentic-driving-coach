reactor Driver{
    input instr
    input eye_reading
    input head_reading
    input brake_reading 
    input accel_reading
    input steer_reading
    output steer
    output accelerator
    output brake
    output head
    output eye

    reaction(eye_reading, head_reading, brake_reading, accel_reading, steer_reading, instr)-> eye, accelerator, brake, steer, head{=
        # if t.is_present: 
          
        eye1 = eye_reading.value
        head1= head_reading.value
        brake1 = brake_reading.value
        accelerator1= accel_reading.value
        steer1 = steer_reading.value
        steer.set(steer1)
        accelerator.set(accelerator1)
        brake.set(brake1)
        head.set(head1)
        eye.set(eye1)

        print("---------------------------------------")
        print(f"from driver Eye: {eye1} \n")
        print(f"from driver head: {head1} \n")
        print(f"from driver brake: {brake1} \n")
        print(f"from driver accelerator: {accelerator1} \n")

        print(f"from driver steer: {steer1} \n")
        print("---------------------------------------")


        # if instr.is_present:
        #     print(f"{instr.value}]")
    =}
}

reactor Car{
    input steer_in
    input accel_in
    input brake_in
    input actuate_in 
    input head_pos_in  
    input eye_pos_in

    state acceleration_net
    state velocity_init = 0.0
    state dist_init = 0.0

    output velocity
    output steer
    output head_pos
    output eye_pos
    

    reaction(accel_in, brake_in, actuate_in)->velocity, steer, head_pos, eye_pos{=
        amsg = accel_in.value if accel_in.is_present else 0.0
        bmsg = brake_in.value if brake_in.is_present else 0.0
        amsg = 0.0 if amsg is None else float(amsg)
        bmsg = 0.0 if bmsg is None else float(bmsg)

        # print("---------------------------------------", flush=True)
        # print(f"from car brake: {bmsg}", flush=True)
        # print(f"from car accelerator: {amsg}", flush=True)
        # print("---------------------------------------", flush=True)
        #pedal position is 0-1 values to get net acceleration p*9.81 but accelerator angle max and brake is 30deg
        # amsg = float(amsg)
        # bmsg = float(bmsg)
        # using piecewise model for accel assuming max m/s2 is 4 and brake 
        def acel_cal(p):
            p = max(0.0, min(1.0, p))
            if p<0.1:
                return 0.0
            elif p<0.6:
                return 2.4 * p
            else:
                return 4.0*(p**2)
        def brake_cal(p):
            p = max(0.0, min(1.0, p))
            if p<0.1:
                return 0.0
            elif p<0.6:
                return -(5.4 * p)
            else:
                return -(9.0*(p**2))
        if bmsg > 0.0:
            self.acceleration_net = brake_cal(bmsg)
        elif amsg > 0.0:
            self.acceleration_net = acel_cal(amsg)
        else:
            # for coasting 
            self.acceleration_net = -0.5

        vel = self.velocity_init + self.acceleration_net * 0.1

        if vel < 0.0:
            vel = 0.0

        d = self.dist_init + vel * 0.1

        print(f"from car Velocity: {vel}", flush=True)
        print(f"from car Distance: {d}", flush=True)

        velocity.set(vel)

        self.velocity_init = vel
        self.dist_init = d
    =}
}

reactor Environment{
    input v
    state pos_stop_sign = 100.0
    state passed = False
    output displacement
 
    reaction(v)->displacement{=
        vn = float(v.value)
        step = vn * 0.1

        if not self.passed:
            self.pos_stop_sign -= step
            if self.pos_stop_sign <= 0.0:
                self.pos_stop_sign = 0.0
                self.passed = True

            displacement.set(self.pos_stop_sign)
        else:
            
            displacement.set(0.0)
        print(f"displacement from the environment: {displacement.value}", flush=True)

    =}
}

