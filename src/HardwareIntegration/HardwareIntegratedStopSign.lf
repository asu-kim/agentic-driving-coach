main reactor{
    d = new Driver()
    sen = new SensorInputs()
    c = new Car()
    en = new Environment()
    // adc = new Coach()

    d.accelerator -> c.accel_in 
    d.brake -> c.brake_in 
    d.steer -> c.steer_in 
    d.head-> c.head_pos_in 
    d.eye -> c.eye_pos_in 

    sen.eye_msg -> d.eye_reading
    sen.brake_msg -> d.brake_reading
    sen.accel_msg -> d.accel_reading
    sen.head_msg -> d.head_reading
    sen.steer_msg -> d.steer_reading

    c.velocity -> en.v
    // c.velocity -> adc.v
    // c.steer -> adc.st
    // c.head_pos -> adc.h

    // en.displacement -> adc.s


    // adc.act -> c.actuate_in after 200 ms
    // adc.instr -> d.instr  
}