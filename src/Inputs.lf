/*
* sudo usermod -aG input raspdeeksha
* sudo usermod -aG video raspdeeksha
* to test the device $ python -m evdev.evtest
* * https://python-evdev.readthedocs.io/en/latest/apidoc.html#evdev.events.InputEvent to understand the evdev python library for linux
*/

target Python {keepalive: true}

import DeviceReader from "SensorReader.lf"
import FaceLandmark from "HeadPoseEstimation.lf"
preamble{=
  import cv2
=}


reactor steering_wheel{
   input steer
   output steer_msg
   state deadzone = 0.04

   reaction(steer) -> steer_msg {=
        s = steer.value
        dz = self.deadzone

        if s < -dz:
            steer_msg.set("LEFT")
        elif s > dz:
            steer_msg.set("RIGHT")
        else:
            steer_msg.set("STRAIGHT")
   =}
}

reactor accelerator{
    input accelerate
    output accel_msg

    reaction(accelerate) -> accel_msg {=
        a = accelerate.value
        accel_msg.set(f"Accelerate {a:.4f}")
  =}
}

reactor brake{
    input brake
    output brake_msg

    reaction(brake) -> brake_msg {=
        b = brake.value
        brake_msg.set(f"Brake {b:.4f}")
  =}
}

reactor webcam{
    input vid 
    output frame_fps
    timer t(0, 100 msec)
    state latest
    
    reaction(startup){=
      self.latest = None
    =}
    reaction(vid) {=
      self.latest = vid.value 
    =}
    reaction(t) -> frame_fps {=
      if self.latest is not None:
        frame_fps.set(self.latest)
    =}
}

// reactor SpeedCalculator(max_speed_meter_p_s = 44.7, initial_speed = 0.0){
//   input throttle
//   input brake
//   output speed_mph


// }

reactor Inputs{
    output steer_msg
    output accel_msg
    output brake_msg
    output head_msg
    output eye_msg

    dev = new DeviceReader()
    wheel = new steering_wheel()
    acc = new accelerator()
    brk = new brake()
    video = new webcam()
    face_detect = new FaceLandmark()

    dev.steer -> wheel.steer
    wheel.steer_msg -> steer_msg

    dev.brake -> brk.brake
    brk.brake_msg -> brake_msg

    dev.throttle -> acc.accelerate
    acc.accel_msg -> accel_msg

    dev.frame -> video.vid
    video.frame_fps -> face_detect.frame
    face_detect.head_msg -> head_msg
    face_detect.eye_msg  -> eye_msg
}