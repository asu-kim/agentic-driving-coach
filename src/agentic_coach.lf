target Python {keepalive: true}

import DrivingInputs from "inputs.lf"

preamble{=
=}

reactor SensorInputs{
    input steer_msg
    input accel_msg
    input brake_msg
    input head_msg
    input eye_msg
    output combined_msg
    reaction(steer_msg, accel_msg, brake_msg, head_msg, eye_msg)-> combined_msg{=
        #Debug
        if steer_msg.is_present:
            print(f"AGENT {steer_msg.value}")

        if accel_msg.is_present:
            print(f"AGENT {accel_msg.value}")

        if brake_msg.is_present:
            print(f"AGENT {brake_msg.value}")

        if head_msg.is_present:
            print(f"AGENT {head_msg.value}")

        if eye_msg.is_present:
            print(f"AGENT {eye_msg.value}")
        #combining all mesages into one to send it to the LLM
        if (steer_msg.is_present | accel_msg.is_present | brake_msg.is_present | head_msg.is_present | eye_msg.is_present):
            combined_msg.set(f"The steering wheel is pointing: {steer_msg.value}, the accelerator value is: {accel_msg.value}, the brake value is {brake_msg.value}, the head is at: {head_msg.value}, the eyes are: {eye_msg.value}.")
    =}
}

reactor AgenticLlm{
    input monitor_msg
    output feedback

    initial mode monitoring{
        
    }

    mode warning{

    }

    mode actuation{

    }

}

main reactor{
    sensor_inputs = new DrivingInputs()
    sensor = new SensorInputs()
    agent = new AgenticLlm()
    sensor_inputs.steer_msg -> sensor.steer_msg
    sensor_inputs.accel_msg -> sensor.accel_msg
    sensor_inputs.brake_msg -> sensor.brake_msg
    sensor_inputs.head_msg  -> sensor.head_msg
    sensor_inputs.eye_msg   -> sensor.eye_msg
    sensor.combined_msg -> agent.monitor_msg
}