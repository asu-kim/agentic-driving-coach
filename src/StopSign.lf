target Python {keepalive: true}

preamble{=
    import ollama
    import time
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    
    ALLOWED = {"NONE", "NOTIFY", "WARNING", "ACTUATE"}

    def run_llm_message(rd_val, v_val):
        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3:8b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "Output exactly ONE line: TOKEN|MSG"
                        "TOKEN must be one of: NONE, NOTIFY, WARNING, ACTUATE"
                        "MSG must be <= 12 words, about stopping only."
                        "Use meters and m/s only."

                        "Rules for TOKEN:"
                        "- if distance_to_stop <= 25 and speed > 2.5: TOKEN=ACTUATE"
                        "- else if 50 < distance_to_stop <= 60 and (speed > 9 or speed < 5): TOKEN=WARNING"
                        "- else if distance_to_stop >= 99 and (speed > 13 or speed < 3): TOKEN=NOTIFY"
                       " - else TOKEN=NONE"

                        "If TOKEN=NONE, output: NONE|"
                        "Do not output anything else."
                    ),
                },
                {
                    "role": "user",
                    "content": f"distance_to_stop={rd_val:.2f}m speed={v_val:.2f}m/s",
                },
            ],
            options={"temperature": 0.0, "num_predict": 30},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()

        tok = "NONE"
        msg = ""

        if raw:
            line = raw.splitlines()[0].strip()
            parts = [p.strip() for p in line.split("|", 1)]
            if len(parts) >= 1:
                tok = parts[0].upper().strip()
            if len(parts) == 2:
                msg = parts[1].strip()

        # Drop unexpected token
        if tok not in ALLOWED:
            tok = "NONE"
            msg = ""

        msg = msg.replace("$", "").replace("`", "").strip().strip('"').strip("'")

        bad = ["token", "message", "rd=", "v=", "distance_to", "speed="]
        if any(b in msg.lower() for b in bad):
            msg = ""

        if tok != "NONE" and not msg:
            if tok == "NOTIFY":
                msg = "Stop sign ahead."
            elif tok == "WARNING":
                msg = "Slow down and prepare to stop."
            elif tok == "ACTUATE":
                msg = "Brake now."

        if tok == "NONE":
            msg = ""

        return tok, msg, ms

    def fallback_policy(rd_val, v_val):
        if rd_val <= 0.0:
            # past the sign: stop issuing
            return "NONE", ""

      
        if rd_val <= 25.0 and v_val > 2.5:
            return "ACTUATE", "Brake now."

        
        if 50.0 < rd_val <= 60.0 and (v_val > 9.0 or v_val < 5.0):
            return "WARNING", "Adjust speed and prepare to stop."

        
      
        if rd_val >= 99.0 and (v_val > 13.0 or v_val < 3.0):
            return "NOTIFY", "Stop sign ahead."

        return "NONE", ""
=}

reactor Driver{
    output steer
    output accelerator
    output brake

    state lines = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehaviorStop.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip() != "":
                        self.lines.append(int(ln.strip()))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake {=
        if self.done:
            return
        if not self.loaded or len(self.lines) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.lines):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        msg = self.lines[self.idx]
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_inp   // external override (Brake or Accelerate)
    input halted

    state acceleration_net
    state velocity_init = 10.0
    state dist_init = 0.0

    output velocity
    output dist_trav

    reaction(accel, brk, ext_inp, halted)->velocity, dist_trav{=
        amsg = accel.value
        bmsg = brk.value

        
        if halted.is_present and halted.value:
            
            pass

      
        if ext_inp.is_present:
            cmd = ext_inp.value
            if cmd in [Brake(5).name, Brake(6).name]:
                bmsg = cmd
            elif cmd in [Accelerate(1).name, Accelerate(2).name, Accelerate(3).name, Accelerate(4).name]:
                amsg = cmd

        
        if bmsg == Brake(5).name:
            self.acceleration_net = -3.0
        elif bmsg == Brake(6).name:
            self.acceleration_net = -9.0
        elif amsg == Accelerate(1).name:
            self.acceleration_net = -0.1
        elif amsg == Accelerate(2).name:
            self.acceleration_net = 0.1
        elif amsg == Accelerate(3).name:
            self.acceleration_net = 2.0
        elif amsg == Accelerate(4).name:
            self.acceleration_net = 4.0
        else:
            self.acceleration_net = 0.0

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0

        d = self.dist_init + v * 0.1

        velocity.set(v)
        dist_trav.set(d)

        self.velocity_init = v
        self.dist_init = d
    =}
}

reactor Environment{
    input velocity_ms
    state pos_stop_sign = 100.0
    state passed = False

    output relative_distance
    output dist_aft_stop

    reaction(velocity_ms)->relative_distance, dist_aft_stop{=
        vn = float(velocity_ms.value)
        step = vn * 0.1

        if not self.passed:
            self.pos_stop_sign -= step
            if self.pos_stop_sign <= 0.0:
                self.pos_stop_sign = 0.0
                self.passed = True
                halted.set(True)

            relative_distance.set(self.pos_stop_sign)
            dist_aft_stop.set(0.0)
        else:
            
            relative_distance.set(0.0)
            dist_aft_stop.set(0.0)
    =}
}

reactor LlmDecision {
    input rd
    input v
    input dist_aft_stop

    output decision
    output driver_msg

    state last_dl_tok = ""
    state last_dl_msg = ""

    reaction(rd, v, dist_aft_stop) -> decision, driver_msg {=
        d_val  = dist_aft_stop.value if dist_aft_stop.value is not None else 0.0
        rd_val = rd.value            if rd.value is not None else 0.0
        v_val  = v.value             if v.value is not None else 0.0

        
        if d_val > 0.0 or rd_val <= 0.0:
            decision.set("NONE")
            driver_msg.set("")
            return

        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DISTANCE after speed]: {d_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)

        tok, msg, ms = run_llm_message(rd_val, v_val)

        
        self.check_deadline()

        decision.set(tok)
        driver_msg.set(msg)

        print(f"[LLM] {ms:.1f} ms -> {tok} | {msg}", flush=True)
    =}

    deadline(100 msec) {=
        rd_val = rd.value if rd.value is not None else 0.0
        v_val  = v.value  if v.value is not None else 0.0
        d_val  = dist_aft_stop.value if dist_aft_stop.value is not None else 0.0

        if d_val > 0.0 or rd_val <= 0.0:
            tok, msg = "NONE", ""
        else:
            tok, msg = fallback_policy(rd_val, v_val)

        
        if tok == self.last_dl_tok and msg == self.last_dl_msg:
            return
        self.last_dl_tok = tok
        self.last_dl_msg = msg

        decision.set(tok)
        driver_msg.set(msg)

        print("################################################", flush=True)
        print(f"[Relative DISTANCE]: {rd_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[DISTANCE after speed]: {d_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print(f"[speed]: {v_val:.2f}", flush=True)
        print("------------------------------------------------", flush=True)
        print("logical", lf.time.logical_elapsed()/1e6, flush=True)
        print("physical", lf.time.physical_elapsed()/1e6, flush=True)
        print(f"[DEADLINE] fallback -> {tok} | {msg}", flush=True)
    =}
}

reactor Agent {
  input decision_in
  input driver_msg_in
  input rd_in
  input v_in
  output ext_inp_cmd

  state last_printed = ""

  initial mode monitoring {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> warning, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value) if rd_in.value is not None else 0.0
      v   = float(v_in.value)  if v_in.value is not None else 0.0

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw in ["WARNING", "NOTIFY"]:
        warning.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> monitoring, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value) if rd_in.value is not None else 0.0
      v   = float(v_in.value)  if v_in.value is not None else 0.0

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0:
        actuate.set()
      elif kw == "NONE":
        monitoring.set()
    =}
  }

  mode actuate {
    reaction(decision_in, rd_in, v_in) -> ext_inp_cmd, monitoring {=
        kw = decision_in.value
        rd = float(rd_in.value) if rd_in.value is not None else 0.0
        v  = float(v_in.value)  if v_in.value is not None else 0.0

        print(f"[ACTUATE] rd={rd:.2f}  v={v:.2f}  kw={kw}", flush=True)

        if kw != "ACTUATE":
            print("[ACTUATE] exit (kw != ACTUATE)", flush=True)
            monitoring.set()
            return

        
        ext_inp_cmd.set(Brake(6).name)
        print("[ACTUATE] sent ext_inp_cmd=EmergencyBraking", flush=True)

        monitoring.set()
    =}
  }
}

reactor Coach{
    input rel_distance
    input velocity_ms
    input dist_aft_stop
    output ext_inp_cmd

    logical action actuation_command

    llm = new LlmDecision()
    agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v
    dist_aft_stop -> llm.dist_aft_stop

    llm.decision -> agent.decision_in
    llm.driver_msg -> agent.driver_msg_in

    rel_distance -> agent.rd_in
    velocity_ms  -> agent.v_in

    // Actuation delay
    agent.ext_inp_cmd -> ext_inp_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel after 500 ms
    d.brake -> c.brk after 500 ms
    d.steer -> c.steer after 500 ms

    c.velocity -> en.velocity_ms
    c.velocity -> adc.velocity_ms

    en.relative_distance -> adc.rel_distance
    en.dist_aft_stop -> adc.dist_aft_stop

    adc.ext_inp_cmd -> c.ext_inp after 200 ms
}