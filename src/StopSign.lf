target Python {keepalive: true}

preamble{=
    import requests
    import ollama
    import time
    import threading
    from enum import Enum

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9

    def run_llm(prompt):
        r = ollama.chat(
            model="llama3.2:1b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "You are a deterministic rule executor.\n"
                        "You MUST follow the policy exactly.\n"
                        "Do NOT invent rules.\n"
                        "Do NOT explain.\n"
                        "Return ONLY the allowed token."
                    )
                },
                {
                    "role": "user",
                    "content": prompt
                }
            ],
            options={
                "temperature": 0.0,
                "num_predict": 5
            }
        )
        return r["message"]["content"].strip()
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state lines = []
    state idx = 0
    state loaded = False
    state done=False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehavior.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip()!= "":
                        self.lines.append(int(ln.strip()))
                
            self.loaded = True
            print(f"Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake, head {=
        if self.done:
            return
        if not self.loaded or len(self.lines)==0:
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                return
        if self.idx >= len(self.lines):
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                return

        msg = self.lines[self.idx]
        print(f"Behavior: {msg}, Index: {self.idx}", flush=True)
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
        elif msg in [7,8,9]:
            head.set(Head(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_brk
    state acceleration_net
    state velocity_init = 10

    state takeover = False
    state takeover_reported = False
    output velocity
    output behavior

    reaction(accel, brk, ext_brk)->velocity, behavior{=

        amsg = accel.value
        bmsg = brk.value
        
        if ext_brk.is_present:
            self.takeover = True
            if not self.takeover_reported:
                behavior.set(True)         
                self.takeover_reported = True   
        if self.takeover:
            self.acceleration_net = (- 9.0)
        else:
            if bmsg == Brake(5).name:
                self.acceleration_net = (- 3.0)
            elif bmsg == Brake(6).name:
                self.acceleration_net = (- 9.0)
            elif amsg == Accelerate(1).name:
                self.acceleration_net = (-0.2)
            elif amsg == Accelerate(2).name:
                self.acceleration_net = (0.5)
            elif amsg == Accelerate(3).name:
                self.acceleration_net = (2.0)
            elif amsg == Accelerate(4).name:
                self.acceleration_net = (4.0)

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0
        velocity.set(v)
        self.velocity_init = v
    =}
}

reactor Environment{
    input velocity_ms
    state start_distance = 0
    state pos_stop_sign = 100
    
    state reported_halt = False
    output halted
    output relative_distance
   

    reaction(velocity_ms)->relative_distance,  halted{=
        vn = velocity_ms.value
        d = self.start_distance + vn * 0.1
        self.start_distance = d
        self.pos_stop_sign -= (vn * 0.1)
        relative_distance.set(self.pos_stop_sign)
        rd = self.pos_stop_sign
        if (not self.reported_halt) and (vn <= 0.0):
            halted.set(True)
            self.reported_halt = True
    =}
}

reactor LlmDecision(deadline_ms=110 msec) {
        input rd
        input v
        output decision
     


        reaction(rd, v) -> decision {=
            policy_text = """\
                POLICY (follow exactly, no new rules)
                Let rd = distance_to_stop_sign_m, v = speed_mps.

                1) If rd >= 99:
                - If 15 < v < 25: NONE
                - Else:           NOTIFY

                2) Else if 70 <= rd <= 80:
                - If v > 16 OR v < 9: ALERT
                - Else:               NONE

                3) Else if 50 < rd <= 60:
                - If 5 < v < 9: WARNING
                - Else:         NONE

                4) Else if rd <= 25:
                - ACTUATE

                5) Else:
                - NONE
                """

            prompt = f"""\
                You are a stop-sign coach.
                Return EXACTLY ONE TOKEN from: NONE NOTIFY ALERT WARNING ACTUATE
                No punctuation. No extra words. No explanation. No newlines.

                distance_to_stop_sign_m={rd.value:.2f}
                speed_mps={v.value:.2f}

                {policy_text}
                """
            msg = run_llm(prompt)
            kw = msg.strip().upper().split()[0]
            if kw not in {"NONE","NOTIFY","ALERT","WARNING","ACTUATE"}:
                kw = "NONE"
            decision.set(kw)
        =} 
        deadline(deadline_ms) {=
            
            
            rd_val = rd.value
            v_val  = v.value

            if rd_val <= 25:
                if v_val >=3:
                    decision.set("ACTUATE")
            elif (50 < rd_val <= 60) and (5 < v_val < 9):
                decision.set("WARNING")
            elif (70 <= rd_val <= 80) and (v_val > 16 or v_val < 9):
                decision.set("ALERT")
            elif rd_val >= 99 and not (15 < v_val < 25):
                decision.set("NOTIFY")
            else:
                decision.set("NONE")
    =}
}

reactor Agent {
  input rel_distance
  input velocity_ms
  input decision_in

  output ext_brk_cmd

  initial mode monitoring {
    reaction(decision_in) -> warning, actuate {=
      kw = decision_in.value
      if kw == "WARNING":
        warning.set()
      elif kw == "ACTUATE":
        actuate.set()
    =}
  }

  mode warning {
    reaction(decision_in) -> actuate {=
        prompt = "Please warn the driver to reduce the speed since there is a stop sign."
        msg = run_llm(prompt)
        print(f"[AGENT WARNING]: {msg}\n")
        kw = decision_in.value
        if kw == "ACTUATE":
            actuate.set()
    =}
  }

  mode actuate {
    reaction(decision_in) -> ext_brk_cmd {=
        prompt = "Please inform the driver that external break is applied since the required action was not taken."
        msg = run_llm(prompt)
        print(f"[AGENT Notice]: {msg}\n")
        ext_brk_cmd.set(Brake(6).name)
    =}
  }
}

reactor Coach{
  input rel_distance
  input velocity_ms
  output ext_brk_cmd

  llm = new LlmDecision()
  Agent = new Agent()

  rel_distance -> llm.rd
  velocity_ms  -> llm.v

  rel_distance -> Agent.rel_distance
  velocity_ms  -> Agent.velocity_ms

  llm.decision -> Agent.decision_in
 

  Agent.ext_brk_cmd -> ext_brk_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel
    d.brake -> c.brk
    d.steer -> c.steer

    c.velocity-> en.velocity_ms
    c.velocity -> adc.velocity_ms

    en.relative_distance -> adc.rel_distance

    adc.ext_brk_cmd -> c.ext_brk after 1 nsec
}