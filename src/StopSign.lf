target Python {keepalive: true}

preamble{=
import ollama
import time
import threading
from enum import Enum

class Accelerate(Enum):
    Coasting = 1
    Cruise = 2
    NormalAcceleration = 3
    StrongAcceleration = 4

class Brake(Enum):
    GentleBraking = 5
    EmergencyBraking = 6

class Head(Enum):
    Left = 7
    Right = 8
    Center = 9

ALLOWED = {"NONE", "NOTIFY", "ALERT", "WARNING", "ACTUATE"}

def warmup_llm():
    try:
        ollama.chat(
            model="llama3.2:1b",
            messages=[{"role": "user", "content": "ping"}],
            options={"temperature": 0.0, "num_predict": 1},
        )
    except Exception:
        pass

def run_llm_decision(prompt):
    t0 = time.perf_counter()
    r = ollama.chat(
        model="llama3.2:1b",
        messages=[
            {
                "role": "system",
                "content": (
                    "Output EXACTLY one line: TOKEN|MESSAGE\n"
                    "TOKEN ∈ {NONE, NOTIFY, ALERT, WARNING, ACTUATE}\n"
                    "MESSAGE: one short sentence.\n"
                    "No other text."
                ),
            },
            {"role": "user", "content": prompt},
        ],
        options={"temperature": 0.0, "num_predict": 80},
    )
    elapsed_ms = (time.perf_counter() - t0) * 1000.0

    raw = (r.get("message", {}).get("content", "") or "").strip()
    line = raw.splitlines()[0].strip() if raw else ""
    if "|" not in line:
        return "NONE", "", elapsed_ms

    token, msg = line.split("|", 1)
    token = token.strip().upper()
    msg = msg.strip()

    if token not in ALLOWED:
        return "NONE", "", elapsed_ms

    return token, msg, elapsed_ms
def warmup_llm_async():
    def _w():
        warmup_llm()
    threading.Thread(target=_w, daemon=True).start()

warmup_llm_async()
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state lines = []
    state idx = 0
    state loaded = False
    state done=False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehavior.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip()!= "":
                        self.lines.append(int(ln.strip()))

            self.loaded = True
            print(f"Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake, head {=
        if self.done:
            return
        if not self.loaded or len(self.lines)==0:
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                return
        if self.idx >= len(self.lines):
                print("Driver behavior not loaded/done", flush=True)
                self.done = True
                return

        msg = self.lines[self.idx]
        print(f"Behavior: {msg}, Index: {self.idx}", flush=True)
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
        elif msg in [7,8,9]:
            head.set(Head(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_brk
    input halted
    state acceleration_net
    state velocity_init = 10

    state takeover = False
    state takeover_reported = False
    output velocity
    output behavior

    reaction(accel, brk, ext_brk, halted)->velocity, behavior{=
        if halted.is_present and halted.value:
            self.takeover = False
            self.takeover_reported = False
        amsg = accel.value
        bmsg = brk.value

        if ext_brk.is_present and (not self.takeover):
            self.takeover = True
            if not self.takeover_reported:
                behavior.set(True)
                self.takeover_reported = True
        if self.takeover:
            self.acceleration_net = (- 9.0)
        else:
            if bmsg == Brake(5).name:
                self.acceleration_net = (- 3.0)
            elif bmsg == Brake(6).name:
                self.acceleration_net = (- 9.0)
            elif amsg == Accelerate(1).name:
                self.acceleration_net = (-0.2)
            elif amsg == Accelerate(2).name:
                self.acceleration_net = (0.5)
            elif amsg == Accelerate(3).name:
                self.acceleration_net = (2.0)
            elif amsg == Accelerate(4).name:
                self.acceleration_net = (4.0)

        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0
        velocity.set(v)
        self.velocity_init = v
    =}
}

reactor Environment{
    input velocity_ms
    state start_distance = 0
    state pos_stop_sign = 100

    state reported_halt = False
    output halted
    output relative_distance

    reaction(velocity_ms)->relative_distance,  halted{=
        vn = velocity_ms.value
        d = self.start_distance + vn * 0.1
        self.start_distance = d
        self.pos_stop_sign -= (vn * 0.1)
        relative_distance.set(self.pos_stop_sign)
        rd = self.pos_stop_sign
        if self.pos_stop_sign <= 0.0:
            self.pos_stop_sign = 0.0
            halted.set(True)
    =}
}


reactor LlmDecision {
    input rd
    input v
    output decision
    output driver_msg

    reaction(rd, v) -> decision, driver_msg {=
        start_ns = lf.time.physical_elapsed()/1e6
        print(f"Start physical time: {start_ns}")
        policy_text = """\
            POLICY (follow exactly, no new rules)
            Let rd = distance_to_stop_sign_m, v = speed_mps.

            1) If rd >= 99:
            - If 15 < v < 25: NONE
            - Else:           NOTIFY

            2) Else if 70 <= rd <= 80:
            - If v > 16 OR v < 9: ALERT
            - Else:               NONE

            3) Else if 50 < rd <= 60:
            - If 5 < v < 9: WARNING
            - Else:         NONE

            4) Else if rd <= 25:
            - ACTUATE

            5) Else:
            - NONE
            """

        prompt = f"""\
            Return exactly: TOKEN|MESSAGE
            TOKEN in: NONE NOTIFY ALERT WARNING ACTUATE
            MESSAGE: one short sentence to the driver.

            distance_to_stop_sign_m={rd.value:.2f}
            speed_mps={v.value:.2f}

            Refer from these rules:
            {policy_text}
            """

        t, m, inf_ms = run_llm_decision(prompt)

        # print(f"[LLM] {inf_ms:.1f} ms -> {t}", flush=True)
       

        missed = self.check_deadline(self)
        elapsed_ms = (lf.time.physical_elapsed()/1e6 - start_ns)   
        print(f"difference physical time: {elapsed_ms}")
        if not missed:
                decision.set(t)
                driver_msg.set(m)
    =}

    deadline(200 msec) {=
        rd_val = rd.value
        v_val  = v.value

        if rd_val >= 99:
            if (v_val > 25) or (v_val < 15):
                t = "NOTIFY";  m = "NOTIFY: Stop sign ahead."
            else:
                t = "NONE";    m = ""
        elif 70 <= rd_val <= 80:
            if v_val > 16 or v_val < 9:
                t = "ALERT";   m = "ALERT: Stop sign ahead."
            else:
                t = "NONE";    m = ""
        elif 50 < rd_val <= 60:
            if 5 > v_val or v_val> 9:
                t = "WARNING"; m = "WARNING: Reduce speed, stop sign ahead."
            else:
                t = "NONE";    m = ""
        elif rd_val <= 25:
            t = "ACTUATE"; m = "ACTUATE: External braking applied."
        else:
            t = "NONE";    m = ""


        decision.set(t)
        driver_msg.set(m)
    =}
}

reactor Agent {
  input decision_in
  input driver_msg_in
  output ext_brk_cmd

  initial mode monitoring {
    reaction(decision_in, driver_msg_in) -> warning, actuate {=
        kw  = decision_in.value
        msg = driver_msg_in.value
        print("[MONITORING]")
        if kw == "ALERT" or kw == "NOTIFY" :
            if msg is not None and msg != "":
                print(msg, flush=True)

        if kw == "WARNING":
            warning.set()
        elif kw == "ACTUATE":
            actuate.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in) -> actuate {=
        kw  = decision_in.value
        msg = driver_msg_in.value
        if kw == "WARNING":
            if msg is not None and msg != "":
                print(msg, flush=True)

        if kw == "ACTUATE":
            actuate.set()
    =}
  }

  mode actuate {
    reaction(decision_in, driver_msg_in) -> ext_brk_cmd {=
      msg = driver_msg_in.value
      if msg is not None and msg != "":
        print(msg, flush=True)
        request_stop()

      ext_brk_cmd.set(Brake(6).name)
    =}
  }
}

reactor Coach{
    input rel_distance
    input velocity_ms
    output ext_brk_cmd

    llm = new LlmDecision()
    Agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v

    // rel_distance -> Agent.rel_distance
    // velocity_ms  -> Agent.velocity_ms

    llm.decision -> Agent.decision_in
    llm.driver_msg -> Agent.driver_msg_in

    Agent.ext_brk_cmd -> ext_brk_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel
    d.brake -> c.brk
    d.steer -> c.steer

    c.velocity-> en.velocity_ms
    c.velocity -> adc.velocity_ms

    en.relative_distance -> adc.rel_distance
    en.halted -> c.halted after 1 nsec

    adc.ext_brk_cmd -> c.ext_brk after 1 nsec
}