target Python {keepalive: true}

preamble{=
    import ollama
    import time
    import threading
    from enum import Enum
    from queue import Queue, Empty

    class Accelerate(Enum):
        Coasting = 1
        Cruise = 2
        NormalAcceleration = 3
        StrongAcceleration = 4

    class Brake(Enum):
        GentleBraking = 5
        EmergencyBraking = 6

    class Head(Enum):
        Left = 7
        Right = 8
        Center = 9

    ALLOWED = {"NONE", "NOTIFY", "ALERT", "WARNING", "ACTUATE"}

    def warmup_llm():
        try:
            ollama.chat(
                model="llama3.2:1b",
                messages=[{"role": "user", "content": "ping"}],
                options={"temperature": 0.0, "num_predict": 1},
            )
        except Exception:
            pass

    def stop_dist(v, a=9.0, buf=1.0):
        if v <= 0.0:
            return 0.0
        return (v * v) / (2.0 * a) + buf

    def warmup_llm_async():
        threading.Thread(target=warmup_llm, daemon=True).start()

    def policy_token(rd_val, v_val):
        # If we've reached/passed the stop sign, stop issuing ACTUATE.
        if rd_val <= 0.0:
            return "NONE"

        if rd_val <= 25 and v_val > 2.5:
            return "ACTUATE"

        if 50 < rd_val <= 60:
            return "WARNING" if not (5 < v_val < 9) else "NONE"

        if 70 <= rd_val <= 80:
            return "ALERT" if (v_val > 16 or v_val < 9) else "NONE"

        if rd_val >= 99:
            return "NOTIFY" if not (15 < v_val < 25) else "NONE"

        return "NONE"

    def run_llm_message(tok, rd_val, v_val):
        if tok == "NONE":
            return tok, "", 0.0

        t0 = time.perf_counter()

        r = ollama.chat(
            model="llama3.2:1b",
            messages=[
                {
                    "role": "system",
                    "content": (
                        "You are a driving coach.\n"
                        "Return ONE short driver instruction (max 12 words).\n"
                        "No token, no quotes, no markdown, no LaTeX, no variables, no explanation.\n"
                        "Only the instruction text."
                    ),
                },
                {
                    "role": "user",
                    "content": f"rd={rd_val:.2f}m v={v_val:.2f}m/s token={tok}",
                },
            ],
            options={"temperature": 0.0, "num_predict": 25},
        )

        ms = (time.perf_counter() - t0) * 1000.0
        raw = (r.get("message", {}).get("content", "") or "").strip()
        msg = raw.splitlines()[0].strip() if raw else ""

        # sanitize common junk
        msg = msg.replace("$", "").replace("`", "")
        msg = msg.strip('"').strip("'").strip()

        # hard guardrails (keeps it from being meta)
        bad = ["token", "message", "position", "velocity", "rd=", "v=", "actuate"]
        if any(b in msg.lower() for b in bad):
            msg = ""

        # fallback by token if LLM gives junk/empty
        if not msg:
            if tok == "NOTIFY":
                msg = "Stop sign ahead."
            elif tok == "ALERT":
                msg = "Stop sign ahead. Pay attention."
            elif tok == "WARNING":
                msg = "Slow down and prepare to stop."
            elif tok == "ACTUATE":
                msg = "Brake now."

        return tok, msg, ms

    warmup_llm_async()
=}

reactor Driver{
    output steer
    output accelerator
    output brake
    output head

    state lines = []
    state idx = 0
    state loaded = False
    state done = False

    timer t(0 msec, 100 msec)

    reaction(startup){=
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/agentic-driving-coach/src/DriverBehavior.txt", "r") as f:
                for ln in f.readlines():
                    if ln.strip() != "":
                        self.lines.append(int(ln.strip()))
            self.loaded = True
            print("Driver has been seated", flush=True)
        except Exception as e:
            print(f"Driver is not seated {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> accelerator, brake, head {=
        if self.done:
            return
        if not self.loaded or len(self.lines) == 0:
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return
        if self.idx >= len(self.lines):
            print("Driver behavior not loaded/done", flush=True)
            self.done = True
            return

        msg = self.lines[self.idx]
        if msg in [1, 2, 3, 4]:
            accelerator.set(Accelerate(msg).name)
        elif msg in [5, 6]:
            brake.set(Brake(msg).name)
        elif msg in [7, 8, 9]:
            head.set(Head(msg).name)

        self.idx += 1
    =}
}

reactor Car{
    input steer
    input accel
    input brk
    input ext_brk
    input halted

    state acceleration_net
    state velocity_init = 10.0

    state takeover = False
    state takeover_reported = False

    output velocity
    output behavior

    reaction(accel, brk, ext_brk, halted)->velocity, behavior{=
        
        if halted.is_present and halted.value:
            self.takeover = False
            self.takeover_reported = False

        amsg = accel.value
        bmsg = brk.value

     
        if ext_brk.is_present:
            self.takeover = True
            if not self.takeover_reported:
                behavior.set(True)
                self.takeover_reported = True

  
        if self.takeover:
            self.acceleration_net = -9.0
        else:
            if bmsg == Brake(5).name:
                self.acceleration_net = -3.0
            elif bmsg == Brake(6).name:
                self.acceleration_net = -9.0
            elif amsg == Accelerate(1).name:
                self.acceleration_net = -1.0
            elif amsg == Accelerate(2).name:
                self.acceleration_net = 3.0
            elif amsg == Accelerate(3).name:
                self.acceleration_net = 5.0
            elif amsg == Accelerate(4).name:
                self.acceleration_net = 10.0

      
        v = self.velocity_init + self.acceleration_net * 0.1
        if v < 0.0:
            v = 0.0

        velocity.set(v)
        self.velocity_init = v
    =}
}

reactor Environment{
    input velocity_ms
    state pos_stop_sign = 100.0

    output halted
    output relative_distance

    reaction(velocity_ms)->relative_distance, halted{=
        vn = velocity_ms.value
        self.pos_stop_sign -= (vn * 0.1)
        if self.pos_stop_sign <= 0.0:
            self.pos_stop_sign = 0.0
            halted.set(True)
        relative_distance.set(self.pos_stop_sign)
    =}
}

reactor LlmDecision {
    input rd
    input v
    output decision
    output driver_msg

    logical action tick

    state q
    state busy = False
    state last_tok = ""
    state last_msg = ""

    reaction(startup){=
        self.q = Queue(maxsize=1)
    =}

    reaction(rd, v) -> tick, decision, driver_msg {=
        if self.q is None:
            return
        if self.busy:
            return
        try:
            while True:
                self.q.get_nowait()
        except Exception:
            pass

        self.busy = True
        print(f"[DISTANCE]: {rd.value:.2f}", flush=True)
        print(f"[speed]: {v.value:.2f}", flush=True)

        def worker(outq):
            rd_val = float(rd.value)
            v_val  = float(v.value)

            tok = policy_token(rd_val, v_val)
            print(tok, flush=True)

            tok, msg, ms = run_llm_message(tok, rd_val, v_val)
            print(f"[LLM] {ms:.1f} ms -> {tok} | {msg}", flush=True)

            try:
                outq.put_nowait((tok, msg, ms))
            except Exception:
                pass

        threading.Thread(target=worker, args=(self.q,), daemon=True).start()

  
        tick.schedule(1) 
    =}

  
    deadline(100 msec) {=
        rd_val = float(rd.value)
        v_val  = float(v.value)

        tok = "NONE"
        msg = ""

        if (v_val > 2.5) and (rd_val <= stop_dist(v_val, a=9.0, buf=1.0)):
            tok = "ACTUATE"
            msg = "Brake now."
        elif 50 < rd_val <= 60:
            if not (5 < v_val < 9):
                tok = "WARNING"
                msg = "Slow down and prepare to stop."
        elif 70 <= rd_val <= 80:
            if v_val > 16 or v_val < 9:
                tok = "ALERT"
                msg = "Stop sign ahead."
        elif rd_val >= 99:
            if (v_val > 25) or (v_val < 15):
                tok = "NOTIFY"
                msg = "Stop sign ahead."

        decision.set(tok)
        driver_msg.set(msg)
        self.busy = False
    =}

    reaction(tick) -> decision, driver_msg {=
        if self.q is None:
            return
        if not self.busy:
            return

        try:
            tok, msg, ms = self.q.get_nowait()
        except Empty:
        
            tick.schedule(10_000_000)
            return

        self.busy = False

        if tok != self.last_tok or msg != self.last_msg:
            decision.set(tok)
            driver_msg.set(msg)
            self.last_tok = tok
            self.last_msg = msg
    =}
}

reactor Agent {
  input decision_in
  input driver_msg_in
  input rd_in
  input v_in
  output ext_brk_cmd

  state last_printed = ""
  state act_cnt = 0

  initial mode monitoring {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> warning, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value)
      v   = float(v_in.value)

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0 and v > 0.05:
        actuate.set()
      elif kw == "WARNING" or kw == "ALERT" or kw == "NOTIFY":
        warning.set()
    =}
  }

  mode warning {
    reaction(decision_in, driver_msg_in, rd_in, v_in) -> monitoring, actuate {=
      kw  = decision_in.value
      msg = driver_msg_in.value
      rd  = float(rd_in.value)
      v   = float(v_in.value)

      if msg and msg != self.last_printed:
        print(msg, flush=True)
        self.last_printed = msg

      if kw == "ACTUATE" and rd > 0.0 and v > 0.05:
        actuate.set()
      elif kw == "NONE":
        monitoring.set()
    =}
  }

  mode actuate {
    reaction(decision_in, rd_in, v_in) -> ext_brk_cmd, monitoring {=
        self.act_cnt += 1
        rd = float(rd_in.value)
        v  = float(v_in.value)
        now_s = lf.time.logical_elapsed()/1e9

        print(f"[ACTUATE] cnt={self.act_cnt} t={now_s:.3f}s rd={rd:.2f} v={v:.2f}", flush=True)

        if (rd <= 0.0) or (v <= 0.05):
            print(f"[ACTUATE->MONITOR] reason={'rd<=0' if rd<=0 else 'v<=0.05'}", flush=True)
            monitoring.set()
            return

        ext_brk_cmd.set(Brake(6).name)
    =}
  }
}

reactor Coach{
    input rel_distance
    input velocity_ms
    output ext_brk_cmd

    llm = new LlmDecision()
    Agent = new Agent()

    rel_distance -> llm.rd
    velocity_ms  -> llm.v

    llm.decision -> Agent.decision_in
    llm.driver_msg -> Agent.driver_msg_in

    rel_distance   -> Agent.rd_in
    velocity_ms    -> Agent.v_in

    Agent.ext_brk_cmd -> ext_brk_cmd
}

main reactor{
    d = new Driver()
    c = new Car()
    en = new Environment()
    adc = new Coach()

    d.accelerator -> c.accel
    d.brake -> c.brk
    d.steer -> c.steer

    c.velocity -> en.velocity_ms
    c.velocity -> adc.velocity_ms

    en.relative_distance -> adc.rel_distance
    en.halted -> c.halted after 1 nsec

    adc.ext_brk_cmd -> c.ext_brk after 1 nsec
}